@page "/projekte"
@rendermode InteractiveServer
@using Softwareschmiede.Domain.Entities
@using Softwareschmiede.Domain.Enums

<PageTitle>Projekte – Softwareschmiede</PageTitle>

<div class="page-header">
    <h2 class="page-title">📁 Projekte</h2>
</div>

<div class="action-bar">
    <button class="btn btn-primary" @onclick="NeuAnlegen">➕ Neues Projekt</button>
</div>

@if (_showForm)
{
    <div class="card">
        <div class="card-title">@(_editId.HasValue ? "Projekt bearbeiten" : "Neues Projekt")</div>
        <div class="form-group">
            <label class="form-label">Name *</label>
            <input class="form-control" @bind="_formName" placeholder="Projektname" />
        </div>
        <div class="form-group">
            <label class="form-label">Beschreibung</label>
            <textarea class="form-control" @bind="_formBeschreibung" placeholder="Optionale Beschreibung" rows="3"></textarea>
        </div>
        @if (!string.IsNullOrEmpty(_fehler))
        {
            <div class="alert alert-error">@_fehler</div>
        }
        <div style="display:flex;gap:.5rem">
            <button class="btn btn-primary" @onclick="SpeichernAsync" disabled="@_saving">
                @if (_saving) { <div class="spinner" style="width:14px;height:14px"></div> } else { <span>💾 Speichern</span> }
            </button>
            <button class="btn btn-ghost" @onclick="FormAbbrechen">Abbrechen</button>
        </div>
    </div>
}

@if (_loading)
{
    <div class="loading"><div class="spinner"></div> Wird geladen...</div>
}
else if (_projekte.Count == 0)
{
    <div class="card">
        <p style="color:#4b5563">Keine Projekte vorhanden. Legen Sie ein erstes Projekt an.</p>
    </div>
}
else
{
    <div class="table-container card">
        <table>
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Beschreibung</th>
                    <th>Status</th>
                    <th>Erstellt</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var p in _projekte)
                {
                    <tr @onclick="() => ZurDetail(p.Id)">
                        <td style="font-weight:600">@p.Name</td>
                        <td style="color:#94a3b8">@(p.Beschreibung ?? "–")</td>
                        <td><ProjektStatusBadge Status="p.Status" /></td>
                        <td style="color:#4b5563;font-size:0.8rem">@p.ErstellungsDatum.ToLocalTime().ToString("dd.MM.yyyy")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
