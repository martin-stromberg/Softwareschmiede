@page "/projekte/{Id:guid}"
@rendermode InteractiveServer
@using Softwareschmiede.Domain.Entities

<PageTitle>@(_projekt?.Name ?? "Projekt") – Softwareschmiede</PageTitle>

@if (_loading)
{
    <div class="loading"><div class="spinner"></div> Wird geladen...</div>
}
else if (_projekt is null)
{
    <div class="alert alert-error">Projekt nicht gefunden.</div>
}
else
{
    <div class="page-header">
        <h2 class="page-title">📁 @_projekt.Name</h2>
        <ProjektStatusBadge Status="_projekt.Status" />
    </div>

    <div class="action-bar">
        @if (_projekt.Status == ProjektStatus.Aktiv)
        {
            <button class="btn btn-primary" @onclick="NeuAufgabe">➕ Neue Aufgabe</button>
            <button class="btn btn-secondary" @onclick="() => _showEditForm = true">✏️ Bearbeiten</button>
            <button class="btn btn-warning" @onclick="ArchivierenAsync">📦 Archivieren</button>
        }
        <button class="btn btn-danger" @onclick="() => _showDeleteConfirm = true">🗑️ Löschen</button>
        <button class="btn btn-ghost" @onclick="ToggleRepositoryFormAsync">🔗 Repository verknüpfen</button>
    </div>
    @if (!string.IsNullOrEmpty(_projekt.Beschreibung))
    {
        <p style="color:#94a3b8;margin-bottom:1rem">@_projekt.Beschreibung</p>
    }

    @if (_showEditForm)
    {
        <div class="card">
            <div class="card-title">Projekt bearbeiten</div>
            <div class="form-group">
                <label class="form-label">Name *</label>
                <input class="form-control" @bind="_editName" />
            </div>
            <div class="form-group">
                <label class="form-label">Beschreibung</label>
                <textarea class="form-control" @bind="_editBeschreibung"></textarea>
            </div>
            @if (!string.IsNullOrEmpty(_fehler)) { <div class="alert alert-error">@_fehler</div> }
            <div style="display:flex;gap:.5rem">
                <button class="btn btn-primary" @onclick="UpdateAsync">💾 Speichern</button>
                <button class="btn btn-ghost" @onclick="() => _showEditForm = false">Abbrechen</button>
            </div>
        </div>
    }

    @if (_showDeleteConfirm)
    {
        <div class="alert alert-error">
            <strong>Projekt wirklich löschen?</strong> Alle Aufgaben und Protokolle werden unwiderruflich gelöscht.
            <div style="display:flex;gap:.5rem;margin-top:.75rem">
                <button class="btn btn-danger" @onclick="DeleteAsync">Ja, löschen</button>
                <button class="btn btn-ghost" @onclick="() => _showDeleteConfirm = false">Abbrechen</button>
            </div>
        </div>
    }

    @if (_showRepoForm)
    {
        <div class="card">
            <div class="card-title">Repository verknüpfen</div>
            <div class="form-group">
                <label class="form-label">SourceCode-Plugin *</label>
                <select class="form-control"
                        value="@_selectedRepositoryPluginPrefix"
                        @onchange="OnRepositoryPluginChangedAsync">
                    @foreach (var plugin in _sourceCodePlugins)
                    {
                        <option value="@plugin.PluginPrefix">@plugin.PluginName (@plugin.PluginPrefix)</option>
                    }
                </select>
            </div>

            @if (_repositoryLinkFields.Count == 0)
            {
                <div class="alert alert-error">Für das ausgewählte Plugin sind keine Felder definiert.</div>
            }
            else
            {
                @foreach (var field in _repositoryLinkFields)
                {
                    var fieldKey = field.Key;
                    <div class="form-group">
                        <label class="form-label">
                            @field.Label
                            @if (field.IsRequired)
                            {
                                <span style="color:#f87171"> *</span>
                            }
                        </label>
                        <input class="form-control"
                               type="@GetRepositoryInputType(field)"
                               value="@GetRepositoryFieldValue(fieldKey)"
                               placeholder="@field.Placeholder"
                               @oninput="e => SetRepositoryFieldValue(fieldKey, e.Value?.ToString() ?? string.Empty)" />
                        @if (!string.IsNullOrWhiteSpace(field.Description))
                        {
                            <small style="color:#6b7280;font-size:.75rem">@field.Description</small>
                        }
                    </div>
                }
            }
            @if (!string.IsNullOrEmpty(_repoFehler)) { <div class="alert alert-error">@_repoFehler</div> }
            <div style="display:flex;gap:.5rem">
                <button class="btn btn-primary" @onclick="AddRepositoryAsync" disabled="@(_sourceCodePlugins.Count == 0)">🔗 Verknüpfen</button>
                <button class="btn btn-ghost" @onclick="() => _showRepoForm = false">Abbrechen</button>
            </div>
        </div>
    }

    <!-- Repositories -->
    <div class="card">
        <div class="card-title">🔗 Repositories</div>
        @if (_projekt.Repositories.Count == 0)
        {
            <p style="color:#4b5563">Keine Repositories verknüpft.</p>
        }
        else
        {
            <table>
                <thead><tr><th>Name</th><th>URL</th><th>Plugin</th><th>Startskript</th><th></th></tr></thead>
                <tbody>
                    @foreach (var repo in _projekt.Repositories.Where(r => r.Aktiv))
                    {
                        <tr>
                            <td>@repo.RepositoryName</td>
                            <td>
                                @if (IsWebUrl(repo.RepositoryUrl))
                                {
                                    <a href="@repo.RepositoryUrl" target="_blank" style="color:#7c3aed">@repo.RepositoryUrl</a>
                                }
                                else
                                {
                                    <code>@repo.RepositoryUrl</code>
                                }
                            </td>
                            <td><code>@repo.PluginTyp</code></td>
                            <td><code>@(repo.StartKonfiguration?.StartScriptRelativePath ?? "–")</code></td>
                            <td>
                                <button class="btn btn-secondary" @onclick="() => StartKonfigurationBearbeiten(repo.Id)">⚙️ Startskript</button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>

    @if (_showStartKonfigurationForm)
    {
        <div class="card">
            <div class="card-title">Repository-Startskript konfigurieren</div>
            <div class="form-group">
                <label class="form-label">Skriptpfad (relativ zum Repository) *</label>
                <input class="form-control" @bind="_startScriptRelativePath" placeholder="scripts/start.ps1" />
            </div>
            <div class="form-group">
                <label class="form-label">
                    <input type="checkbox" checked="@_startKonfigurationAktiv" @onchange="e => _startKonfigurationAktiv = (bool?)e.Value == true" />
                    Aktiv
                </label>
            </div>
            @if (!string.IsNullOrEmpty(_startKonfigurationFehler))
            {
                <div class="alert alert-error">@_startKonfigurationFehler</div>
            }
            <div style="display:flex;gap:.5rem">
                <button class="btn btn-primary" @onclick="SpeichereStartKonfigurationAsync">💾 Speichern</button>
                <button class="btn btn-ghost" @onclick="() => _showStartKonfigurationForm = false">Abbrechen</button>
            </div>
        </div>
    }

    <!-- Aufgaben -->
    <div class="card">
        <div class="card-title">📋 Aufgaben</div>
        @if (_aufgaben.Count == 0)
        {
            <p style="color:#4b5563">Keine Aufgaben vorhanden.</p>
        }
        else
        {
            <table>
                <thead><tr><th>Titel</th><th>Status</th><th>Branch</th><th>Erstellt</th></tr></thead>
                <tbody>
                    @foreach (var a in _aufgaben)
                    {
                        <tr @onclick="() => ZurAufgabe(a.Id)">
                            <td style="font-weight:500">@a.Titel</td>
                            <td><StatusBadge Status="a.Status" /></td>
                            <td><code style="font-size:0.75rem;color:#7c3aed">@(a.BranchName ?? "–")</code></td>
                            <td style="color:#4b5563;font-size:0.8rem">@a.ErstellungsDatum.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>

    <!-- Archivierte Aufgaben (zugeklappt) -->
    <div class="card">
        <div class="card-title" style="cursor:pointer;display:flex;justify-content:space-between;align-items:center"
             @onclick="() => _showArchiviertPanel = !_showArchiviertPanel">
            <span>📦 Archiv (@_aufgabenArchiviert.Count)</span>
            <span style="font-size:.85rem;color:#94a3b8">@(_showArchiviertPanel ? "▲ Einklappen" : "▼ Ausklappen")</span>
        </div>
        @if (_showArchiviertPanel)
        {
            @if (_aufgabenArchiviert.Count == 0)
            {
                <p style="color:#4b5563">Keine archivierten Aufgaben.</p>
            }
            else
            {
                <table>
                    <thead><tr><th>Titel</th><th>Branch</th><th>Erstellt</th></tr></thead>
                    <tbody>
                        @foreach (var a in _aufgabenArchiviert)
                        {
                            <tr @onclick="() => ZurAufgabe(a.Id)" style="opacity:.7">
                                <td style="font-weight:500">@a.Titel</td>
                                <td><code style="font-size:0.75rem;color:#94a3b8">@(a.BranchName ?? "–")</code></td>
                                <td style="color:#4b5563;font-size:0.8rem">@a.ErstellungsDatum.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        }
    </div>
}
