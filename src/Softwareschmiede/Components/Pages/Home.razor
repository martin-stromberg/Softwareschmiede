@page "/"
@rendermode InteractiveServer
@using Softwareschmiede.Domain.Entities
@using Softwareschmiede.Domain.Enums

<PageTitle>Dashboard – Softwareschmiede</PageTitle>

<div class="page-header">
    <h2 class="page-title">⚒️ Dashboard</h2>
</div>

@if (_loading)
{
    <div class="loading"><div class="spinner"></div> Wird geladen...</div>
}
else
{
    <div class="grid-3" style="margin-bottom:1.5rem">
        <div class="stat-card">
            <div class="stat-value">@_aktiveProjekte</div>
            <div class="stat-label">Aktive Projekte</div>
        </div>
        <div class="stat-card">
            <div class="stat-value">@_offeneAufgaben</div>
            <div class="stat-label">Offene Aufgaben</div>
        </div>
        <div class="stat-card">
            <div class="stat-value">@_kiAktiveAufgaben</div>
            <div class="stat-label">KI aktiv</div>
        </div>
    </div>

    <div class="card">
        <div class="card-title">Aktive Aufgaben</div>
        @if (_aktiveAufgaben.Count == 0)
        {
            <p style="color:#4b5563">Keine aktiven Aufgaben.</p>
        }
        else
        {
            <div class="table-container">
                <table>
                    <thead>
                        <tr>
                            <th>Titel</th>
                            <th>Projekt</th>
                            <th>Status</th>
                            <th>Branch</th>
                            <th>Erstellt</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var aufgabe in _aktiveAufgaben)
                        {
                            <tr @onclick="() => NavigateToAufgabe(aufgabe.Id)">
                                <td>@aufgabe.Titel</td>
                                <td>@GetProjektName(aufgabe.ProjektId)</td>
                                <td><StatusBadge Status="aufgabe.Status" /></td>
                                <td><code style="font-size:0.75rem;color:#7c3aed">@aufgabe.BranchName</code></td>
                                <td style="color:#4b5563;font-size:0.8rem">@aufgabe.ErstellungsDatum.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
}
