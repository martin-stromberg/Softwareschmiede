@page "/einstellungen"
@rendermode InteractiveServer
@using System.IO
@using Softwareschmiede.Domain.ValueObjects
@inherits EinstellungenBase

<div class="page-header">
    <h2>⚙️ Einstellungen</h2>
</div>

<div class="card" style="margin-bottom:1.5rem">
    <div class="card-title">📁 Arbeitsverzeichnis für lokale Repositories</div>

    @if (!string.IsNullOrEmpty(_arbeitsverzeichnisStatusMessage))
    {
        <div class="alert @(_arbeitsverzeichnisStatusIsError ? "alert-error" : "alert-success")" style="margin-bottom:1rem">
            @_arbeitsverzeichnisStatusMessage
        </div>
    }

    @if (!string.IsNullOrEmpty(_arbeitsverzeichnisFallbackHinweis))
    {
        <div class="alert alert-error" style="margin-bottom:1rem">
            @_arbeitsverzeichnisFallbackHinweis
        </div>
    }

    <div class="form-group">
        <label class="form-label">Arbeitsverzeichnis</label>
        <input type="text"
               class="form-input"
               value="@_arbeitsverzeichnisInput"
               @oninput="e => ArbeitsverzeichnisInputChanged(e.Value?.ToString() ?? string.Empty)"
               placeholder="@Path.Combine(Path.GetTempPath(), "softwareschmiede")" />
        <small style="color:#6b7280;font-size:.75rem">
            Leer lassen für den Default: @Path.Combine(Path.GetTempPath(), "softwareschmiede")
        </small>
        @if (!string.IsNullOrEmpty(_arbeitsverzeichnisValidationError))
        {
            <small style="color:#f87171;display:block;margin-top:.25rem">@_arbeitsverzeichnisValidationError</small>
        }
    </div>

    <div class="action-bar">
        <button class="btn btn-primary"
                @onclick="ArbeitsverzeichnisSpeichernAsync"
                disabled="@(_saving || !string.IsNullOrEmpty(_arbeitsverzeichnisValidationError))">
            💾 Speichern
        </button>
        <button class="btn btn-ghost"
                @onclick="ArbeitsverzeichnisZuruecksetzenAsync"
                disabled="@_saving">
            ↩️ Default verwenden
        </button>
    </div>
</div>

<div class="card" style="margin-bottom:1.5rem">
    <div class="card-title">⭐ Standard-Plugins</div>

    <div class="form-group">
        <label class="form-label">Source Code Management</label>
        <select class="form-control" @bind="_defaultPluginSelections[Softwareschmiede.Domain.Enums.PluginType.SourceCodeManagement]">
            <option value="">– Kein Standard gesetzt –</option>
            @foreach (var plugin in _sourceCodeManagementPlugins)
            {
                <option value="@plugin.PluginPrefix">@plugin.PluginName (@plugin.PluginPrefix)</option>
            }
        </select>
        @if (!string.IsNullOrEmpty(_defaultPluginStatusMessages.GetValueOrDefault(Softwareschmiede.Domain.Enums.PluginType.SourceCodeManagement)))
        {
            var isError = _defaultPluginStatusIsError.GetValueOrDefault(Softwareschmiede.Domain.Enums.PluginType.SourceCodeManagement);
            <small style="display:block;margin-top:.25rem;color:@(isError ? "#f87171" : "#34d399")">
                @_defaultPluginStatusMessages[Softwareschmiede.Domain.Enums.PluginType.SourceCodeManagement]
            </small>
        }
    </div>

    <div class="form-group">
        <label class="form-label">Development Automation (KI)</label>
        <select class="form-control" @bind="_defaultPluginSelections[Softwareschmiede.Domain.Enums.PluginType.DevelopmentAutomation]">
            <option value="">– Kein Standard gesetzt –</option>
            @foreach (var plugin in _developmentAutomationPlugins)
            {
                <option value="@plugin.PluginPrefix">@plugin.PluginName (@plugin.PluginPrefix)</option>
            }
        </select>
        @if (!string.IsNullOrEmpty(_defaultPluginStatusMessages.GetValueOrDefault(Softwareschmiede.Domain.Enums.PluginType.DevelopmentAutomation)))
        {
            var isError = _defaultPluginStatusIsError.GetValueOrDefault(Softwareschmiede.Domain.Enums.PluginType.DevelopmentAutomation);
            <small style="display:block;margin-top:.25rem;color:@(isError ? "#f87171" : "#34d399")">
                @_defaultPluginStatusMessages[Softwareschmiede.Domain.Enums.PluginType.DevelopmentAutomation]
            </small>
        }
    </div>

    <div class="action-bar">
        <button class="btn btn-primary"
                @onclick="() => StandardPluginSpeichernAsync(Softwareschmiede.Domain.Enums.PluginType.SourceCodeManagement)"
                disabled="@_saving">
            💾 SCM speichern
        </button>
        <button class="btn btn-primary"
                @onclick="() => StandardPluginSpeichernAsync(Softwareschmiede.Domain.Enums.PluginType.DevelopmentAutomation)"
                disabled="@_saving">
            💾 KI speichern
        </button>
    </div>
</div>

@foreach (var plugin in _plugins)
{
    <div class="card" style="margin-bottom:1.5rem">
        <div class="card-title">🔌 @plugin.Plugin.PluginName</div>

        @if (!string.IsNullOrEmpty(_statusMessages.GetValueOrDefault(plugin.Plugin.PluginPrefix)))
        {
            var isErr = _errorFlags.GetValueOrDefault(plugin.Plugin.PluginPrefix);
            <div class="alert @(isErr ? "alert-error" : "alert-success")" style="margin-bottom:1rem">
                @_statusMessages[plugin.Plugin.PluginPrefix]
            </div>
        }

        @foreach (var group in plugin.Plugin.GetSettingGroups())
        {
            <fieldset style="border:1px solid #374151;border-radius:.5rem;padding:1rem;margin-bottom:1rem">
                <legend style="color:#94a3b8;font-size:.8rem;padding:0 .5rem">@group.GroupName</legend>

                @foreach (var field in group.Fields)
                {
                    var stateKey = $"{plugin.Plugin.PluginPrefix}.{field.Key}";
                    <div class="form-group">
                        <label class="form-label">
                            @field.Label
                            @if (field.IsRequired) { <span style="color:#f87171"> *</span> }
                        </label>

                        @if (field.FieldType == PluginSettingFieldType.Boolean)
                        {
                            <input type="checkbox"
                                   checked="@(_inputValues.GetValueOrDefault(stateKey) == BoolTrue)"
                                   @onchange="e => _inputValues[stateKey] = ((bool?)e.Value == true) ? BoolTrue : BoolFalse" />
                        }
                        else
                        {
                            var inputType = field.FieldType == PluginSettingFieldType.Secret
                                ? (_visibleSecrets.GetValueOrDefault(stateKey) ? "text" : "password")
                                : field.FieldType == PluginSettingFieldType.Url ? "url"
                                : field.FieldType == PluginSettingFieldType.Integer ? "number"
                                : "text";

                            <div style="display:flex;gap:.5rem;align-items:center">
                                <input type="@inputType"
                                       class="form-input"
                                       style="flex:1;@(field.FieldType == PluginSettingFieldType.Secret ? "font-family:monospace" : "")"
                                       value="@_inputValues.GetValueOrDefault(stateKey, string.Empty)"
                                       @oninput="e => _inputValues[stateKey] = e.Value?.ToString() ?? string.Empty"
                                       placeholder="@field.Placeholder" />
                                @if (field.FieldType == PluginSettingFieldType.Secret)
                                {
                                    <button class="btn btn-secondary"
                                            style="padding:.4rem .6rem"
                                            @onclick="() => ToggleVisible(stateKey)"
                                            title="@(_visibleSecrets.GetValueOrDefault(stateKey) ? "Verbergen" : "Anzeigen")">
                                        @(_visibleSecrets.GetValueOrDefault(stateKey) ? "🙈" : "👁️")
                                    </button>
                                }
                            </div>
                        }

                        @if (!string.IsNullOrEmpty(field.Description))
                        {
                            <small style="color:#6b7280;font-size:.75rem">@field.Description</small>
                        }

                        @if (_hasValues.GetValueOrDefault(stateKey) && string.IsNullOrWhiteSpace(_inputValues.GetValueOrDefault(stateKey)))
                        {
                            <small style="color:#34d399;display:block;margin-top:.25rem">✅ Gespeichert</small>
                        }
                    </div>
                }
            </fieldset>
        }

        <div class="action-bar">
            <button class="btn btn-primary"
                    @onclick="() => SpeichernAsync(plugin.Plugin)"
                    disabled="@_saving">
                💾 Speichern
            </button>
            <button class="btn btn-ghost"
                    @onclick="() => ZuruecksetzenAsync(plugin.Plugin)"
                    disabled="@_saving">
                ↩️ Zurücksetzen
            </button>
        </div>
    </div>
}
