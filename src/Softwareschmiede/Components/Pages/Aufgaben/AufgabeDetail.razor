@page "/aufgaben/{Id:guid}"
@rendermode InteractiveServer
@using Softwareschmiede.Domain.Entities
@using Softwareschmiede.Domain.Enums
@using Softwareschmiede.Domain.ValueObjects
@implements IDisposable

<PageTitle>@(_aufgabe?.Titel ?? "Aufgabe") – Softwareschmiede</PageTitle>

@if (_loading)
{
    <div class="loading"><div class="spinner"></div> Wird geladen...</div>
}
else if (_aufgabe is null)
{
    <div class="alert alert-error">Aufgabe nicht gefunden.</div>
}
else
{
    <div class="page-header">
        <button class="btn btn-ghost" @onclick="Zurueck">← Zurück</button>
        <h2 class="page-title">@_aufgabe.Titel</h2>
        <StatusBadge Status="_aufgabe.Status" />
    </div>

    <!-- Aktionsleiste -->
    <div class="action-bar">
        @if (_aufgabe.Status == AufgabeStatus.Offen)
        {
            <button class="btn btn-primary" @onclick="StartDialogOeffnen" disabled="@_processing">🚀 Entwicklung starten</button>
        }
        @if (_aufgabe.Status is AufgabeStatus.InBearbeitung or AufgabeStatus.KiAktiv)
        {
            <button class="btn btn-secondary" @onclick="RepositoryStartskriptAusfuehrenAsync" disabled="@_processing">▶️ Startskript ausführen</button>
            <button class="btn btn-success" @onclick="() => _showCommitForm = true" disabled="@(_aufgabe.Status == AufgabeStatus.KiAktiv)">📝 Commit</button>
            @if (_gitActionVisibility.ShowPushPullToggle)
            {
                <button class="btn btn-secondary" @onclick="() => _showPushPullButtons = !_showPushPullButtons">🔄 Push/Pull</button>
            }
            @if (_gitActionVisibility.ShowPullRequest)
            {
                <button class="btn btn-warning" @onclick="() => _showPullRequestForm = true">🔀 Pull Request</button>
            }
            @if (_gitActionVisibility.ShowMerge)
            {
                <button class="btn btn-info" @onclick="MergeToSourceAsync" disabled="@_processing">🔀 Merge</button>
            }
            <button class="btn btn-secondary" @onclick="() => _showResetForm = true" disabled="@(_aufgabe.Status == AufgabeStatus.KiAktiv)">↩️ Reset</button>
            @if (_aufgabe.Status == AufgabeStatus.KiAktiv)
            {
                <button class="btn btn-warning"
                        @onclick="() => _showStatusResetConfirm = true"
                        disabled="@(_processing || !_statusResetAllowed)"
                        title="@(_statusResetDisabledReason ?? "Setzt die Aufgabe auf 'In Bearbeitung' zurück, damit eine neue Anfrage möglich ist.")">
                    ↩️ Status zurücksetzen
                </button>
            }
        }
        @if (IsRecoveryStatus)
        {
            <button class="btn btn-warning"
                    @onclick="() => _showRecoveryConfirm = true"
                    disabled="@(_processing || !_recoveryAllowed)"
                    title="@(_recoveryDisabledReason ?? "Setzt festhängende Aufgabe wieder auf 'In Bearbeitung'.")">
                🩹 Aufgabe wiederherstellen
            </button>
        }
        @if (_showExplorer)
        {
            <button class="btn btn-ghost" @onclick="SwitchToTaskViewAsync">← Zur Aufgabe</button>
        }
        else
        {
            <button class="btn btn-ghost" @onclick="SwitchToExplorerViewAsync">🗂️ Projektverzeichnis</button>
        }
        <button class="btn btn-ghost" @onclick="ExplorerRefreshAsync" disabled="@_loadingWorkspace">↻ Aktualisieren</button>
        @if (_aufgabe.Status == AufgabeStatus.InBearbeitung)
        {
            <button class="btn btn-success" @onclick="AbschliessenAsync">✅ Abschließen</button>
            <button class="btn btn-danger" @onclick="() => _showAbbrechenConfirm = true">🛑 Abbrechen</button>
        }
        @if (_aufgabe.Status is AufgabeStatus.Abgeschlossen or AufgabeStatus.Fehlgeschlagen or AufgabeStatus.Archiviert)
        {
            @if (_aufgabe.Status != AufgabeStatus.Archiviert)
            {
                <button class="btn btn-warning" @onclick="() => _showArchivierenConfirm = true" disabled="@_processing">📦 Archivieren</button>
            }
            <button class="btn btn-danger" @onclick="() => _showDeleteConfirm = true" disabled="@_processing">🗑️ Löschen</button>
        }
    </div>

    <div class="grid-3" style="margin-bottom:1rem">
        <div class="stat-card">
            <div class="stat-value">@(_workspaceSnapshot?.CommitCount ?? 0)</div>
            <div class="stat-label">Commits</div>
        </div>
        <div class="stat-card">
            <div class="stat-value">@(_workspaceSnapshot?.ChangedFileCount ?? 0)</div>
            <div class="stat-label">Geänderte Dateien</div>
        </div>
        <div class="stat-card">
            <div class="stat-value">@(_showExplorer ? "Tree" : "Task")</div>
            <div class="stat-label">Ansicht</div>
        </div>
    </div>

    @if (IsRecoveryStatus && !_recoveryAllowed && !string.IsNullOrWhiteSpace(_recoveryDisabledReason))
    {
        <div class="alert alert-info">@_recoveryDisabledReason</div>
    }

    @if (_aufgabe.Status == AufgabeStatus.KiAktiv && !_statusResetAllowed && !string.IsNullOrWhiteSpace(_statusResetDisabledReason))
    {
        <div class="alert alert-info">@_statusResetDisabledReason</div>
    }

    @if (_showExplorer)
    {
        <div class="card">
            <div class="card-title" style="display:flex;justify-content:space-between;align-items:center">
                <span>🗂️ Repository-Explorer</span>
                <div style="display:flex;gap:.5rem;align-items:center">
                    <button class="btn btn-ghost" @onclick="() => _useTreeLayout = true" disabled="@_useTreeLayout">Baum</button>
                    <button class="btn btn-ghost" @onclick="() => _useTreeLayout = false" disabled="@(!_useTreeLayout)">Liste</button>
                </div>
            </div>

            @if (_loadingWorkspace)
            {
                <div class="loading"><div class="spinner"></div> Repository wird geladen...</div>
            }
            else if (_workspaceSnapshot?.HasError == true)
            {
                <div class="alert alert-warning">@_workspaceSnapshot.ErrorMessage</div>
            }
            else if (_workspaceSnapshot is null)
            {
                <div class="alert alert-warning">Kein Repository-Browser verfügbar.</div>
            }
            else if (_workspaceSnapshot.ChangedFileCount == 0)
            {
                <div class="alert alert-info">Keine geänderten Dateien vorhanden.</div>
            }
            else
            {
                <div class="grid-2">
                    <div class="tree-panel">
                        <div class="tree-header">
                            <span class="tree-header-title">Änderungen</span>
                            <span class="tree-header-title">@(_useTreeLayout ? "Baum" : "Liste")</span>
                        </div>
                        <Virtualize TItem="WorkspaceNodeRow" Items="@VisibleWorkspaceNodes" Context="entry" ItemSize="32">
                            <div class="tree-item @(IsWorkspaceNodeSelected(entry.Node) ? "tree-item-selected" : "")"
                                 style="padding-left:@(entry.Depth * 16 + 8)px"
                                 @onclick="() => WorkspaceNodeClickedAsync(entry.Node)">
                                @if (entry.Node.IsDirectory)
                                {
                                    <svg class="tree-expand-btn" @onclick:stopPropagation @onclick="() => WorkspaceNodeClickedAsync(entry.Node)">
                                        @if (entry.Node.IsExpanded)
                                        {
                                            <use href="/sprite.svg#icon-chevron-down" />
                                        }
                                        else
                                        {
                                            <use href="/sprite.svg#icon-chevron-right" />
                                        }
                                    </svg>
                                }
                                else
                                {
                                    <span style="width:16px;display:inline-block"></span>
                                }

                                <svg class="tree-item-icon">
                                    <use href="/sprite.svg#@(entry.Node.IsDirectory ? "icon-folder" : "icon-file")" />
                                </svg>

                                <span style="flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">@entry.Node.Name</span>

                                @if (entry.Node.IsDirectory)
                                {
                                    <span class="badge badge-offen">@entry.Node.ChangedFileCount</span>
                                }
                                else if (entry.Node.Status is not null)
                                {
                                    <span class="badge @entry.Node.Status.CssClass" title="@entry.Node.Status.Description">@entry.Node.Status.BadgeText</span>
                                }
                            </div>
                        </Virtualize>
                    </div>

                    <div class="card" style="margin-bottom:0">
                        <div class="card-title">Dateivorschau</div>
                        @if (_selectedWorkspacePreview is null)
                        {
                            <p style="color:#94a3b8">Wählen Sie links eine Datei aus.</p>
                        }
                        else if (!string.IsNullOrWhiteSpace(_selectedWorkspacePreview.Hint))
                        {
                            <div class="alert alert-warning">@_selectedWorkspacePreview.Hint</div>
                            @if (_selectedWorkspacePreview.CurrentContent is not null)
                            {
                                <pre class="workspace-preview">@_selectedWorkspacePreview.CurrentContent</pre>
                            }
                        }
                        else
                        {
                            <div class="comparison-grid">
                                <div class="comparison-pane">
                                    <div class="comparison-pane-title">Original</div>
                                    <pre class="workspace-preview">@(_selectedWorkspacePreview.OriginalContent ?? "–")</pre>
                                </div>
                                <div class="comparison-pane">
                                    <div class="comparison-pane-title">Aktuell</div>
                                    <pre class="workspace-preview">@(_selectedWorkspacePreview.CurrentContent ?? (_selectedWorkspacePreview.IsDeleted ? "Datei gelöscht" : "–"))</pre>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    }

    @if (!_showExplorer)
    {
    @if (!string.IsNullOrEmpty(_fehler))
    {
        <div class="alert alert-error">@_fehler <button @onclick="() => _fehler = null" style="float:right;background:none;border:none;color:inherit;cursor:pointer">✕</button></div>
    }
    @if (!string.IsNullOrEmpty(_erfolg))
    {
        <div class="alert alert-success">@_erfolg <button @onclick="() => _erfolg = null" style="float:right;background:none;border:none;color:inherit;cursor:pointer">✕</button></div>
    }

    @if (_showAbbrechenConfirm)
    {
        <div class="alert alert-warning">
            <strong>Aufgabe abbrechen?</strong> Der lokale Klon wird gelöscht. Keine Änderungen werden gepusht.
            <div style="display:flex;gap:.5rem;margin-top:.75rem">
                <button class="btn btn-danger" @onclick="AbbrechenAsync">Ja, abbrechen</button>
                <button class="btn btn-ghost" @onclick="() => _showAbbrechenConfirm = false">Zurück</button>
            </div>
        </div>
    }

    @if (_showRecoveryConfirm)
    {
        <div class="alert alert-warning">
            <strong>Aufgabe wiederherstellen?</strong> Der Status wird auf „In Bearbeitung“ gesetzt, wenn keine Verarbeitung mehr läuft.
            <div style="display:flex;gap:.5rem;margin-top:.75rem">
                <button class="btn btn-warning" @onclick="WiederherstellenAsync" disabled="@_processing">Ja, wiederherstellen</button>
                <button class="btn btn-ghost" @onclick="() => _showRecoveryConfirm = false">Zurück</button>
            </div>
        </div>
    }

    @if (_showStatusResetConfirm)
    {
        <div class="alert alert-warning">
            <strong>Status zurücksetzen?</strong> Die Aufgabe wird auf „In Bearbeitung“ gesetzt. Danach kann eine neue Anfrage gesendet werden.
            <div style="display:flex;gap:.5rem;margin-top:.75rem">
                <button class="btn btn-warning" @onclick="StatusZuruecksetzenAsync" disabled="@_processing">Ja, Status zurücksetzen</button>
                <button class="btn btn-ghost" @onclick="() => _showStatusResetConfirm = false">Zurück</button>
            </div>
        </div>
    }

    @if (_showArchivierenConfirm)
    {
        <div class="alert alert-warning">
            <strong>Aufgabe archivieren?</strong> Die Aufgabe wird in das Archiv verschoben und nicht mehr in der Projektübersicht angezeigt.
            <div style="display:flex;gap:.5rem;margin-top:.75rem">
                <button class="btn btn-warning" @onclick="ArchivierenAsync">📦 Ja, archivieren</button>
                <button class="btn btn-ghost" @onclick="() => _showArchivierenConfirm = false">Zurück</button>
            </div>
        </div>
    }

    @if (_showDeleteConfirm)
    {
        <div class="alert alert-error">
            <strong>Aufgabe löschen?</strong> Die Aufgabe wird mit allen Protokolleinträgen unwiderruflich gelöscht.
            <div style="display:flex;gap:.5rem;margin-top:.75rem">
                <button class="btn btn-danger" @onclick="AufgabeLoeschenAsync">🗑️ Ja, löschen</button>
                <button class="btn btn-ghost" @onclick="() => _showDeleteConfirm = false">Zurück</button>
            </div>
        </div>
    }

    <div class="grid-2">
        <!-- Linke Spalte: Anforderung + Aktionen -->
        <div>
            <!-- Anforderung -->
            <div class="card">
                <div class="card-title" style="display:flex;justify-content:space-between;align-items:center">
                    <span>📋 Anforderung</span>
                    @if (_aufgabe.Status == AufgabeStatus.Offen && !_editAnforderung)
                    {
                        <button class="btn btn-ghost" style="padding:.2rem .5rem;font-size:.8rem" @onclick="AnforderungBearbeitenStarten">✏️ Bearbeiten</button>
                    }
                </div>
                @if (_aufgabe.IssueReferenz is not null)
                {
                    <div style="margin-bottom:.75rem">
                        <span class="badge badge-offen">#@_aufgabe.IssueReferenz.IssueNummer @_aufgabe.IssueReferenz.Titel</span>
                        @if (!string.IsNullOrEmpty(_aufgabe.IssueReferenz.IssueUrl))
                        {
                            <a href="@_aufgabe.IssueReferenz.IssueUrl" target="_blank" style="color:#7c3aed;margin-left:.5rem;font-size:.8rem">↗ GitHub</a>
                        }
                    </div>
                }
                @if (_editAnforderung)
                {
                    <textarea class="form-control" @bind="_anforderungInput" rows="8" style="margin-bottom:.75rem" placeholder="Anforderungsbeschreibung..."></textarea>
                    <div style="display:flex;gap:.5rem">
                        <button class="btn btn-primary" @onclick="AnforderungSpeichernAsync" disabled="@_processing">💾 Speichern</button>
                        <button class="btn btn-ghost" @onclick="AnforderungBearbeitenAbbrechen">Abbrechen</button>
                    </div>
                }
                else
                {
                    <p style="color:#94a3b8;white-space:pre-wrap">@(_aufgabe.AnforderungsBeschreibung ?? "–")</p>
                }
            </div>

            <!-- Git-Aktionen-Formulare -->
            @if (_showCommitForm)
            {
                <div class="card">
                    <div class="card-title">📝 Commit</div>
                    <div class="form-group">
                        <label class="form-label">Commit-Nachricht *</label>
                        <input class="form-control" @bind="_commitMessage" placeholder="feat: Beschreibung der Änderung" />
                    </div>
                    <div style="display:flex;gap:.5rem">
                        <button class="btn btn-primary" @onclick="CommitAsync" disabled="@_processing">✅ Commit</button>
                        <button class="btn btn-ghost" @onclick="() => _showCommitForm = false">Abbrechen</button>
                    </div>
                </div>
            }

            @if (_showPushPullButtons && _gitActionVisibility.ShowPushPullToggle)
            {
                <div class="card">
                    <div class="card-title">🔄 Push / Pull</div>
                    <div style="display:flex;gap:.5rem">
                        @if (_gitActionVisibility.ShowPush)
                        {
                            <button class="btn btn-primary" @onclick="PushAsync" disabled="@_processing">⬆️ Push</button>
                        }
                        @if (_gitActionVisibility.ShowPull)
                        {
                            <button class="btn btn-secondary" @onclick="PullAsync" disabled="@_processing">⬇️ Pull</button>
                        }
                    </div>
                </div>
            }

            @if (_showResetForm)
            {
                <div class="card">
                    <div class="card-title">↩️ Git Reset</div>
                    <div class="form-group">
                        <label class="form-label">Reset-Typ</label>
                        <select class="form-control" @bind="_resetType">
                            <option value="soft">--soft (Index behalten)</option>
                            <option value="mixed">--mixed (Änderungen behalten)</option>
                            <option value="hard">--hard (Alles verwerfen)</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Ziel-Ref (optional, z.B. HEAD~1)</label>
                        <input class="form-control" @bind="_resetRef" placeholder="HEAD~1 oder Commit-Hash" />
                    </div>
                    <div style="display:flex;gap:.5rem">
                        <button class="btn btn-warning" @onclick="ResetAsync" disabled="@_processing">↩️ Reset durchführen</button>
                        <button class="btn btn-ghost" @onclick="() => _showResetForm = false">Abbrechen</button>
                    </div>
                </div>
            }

            @if (_showPullRequestForm && _gitActionVisibility.ShowPullRequest)
            {
                <div class="card">
                    <div class="card-title">🔀 Pull Request erstellen</div>
                    <div class="form-group">
                        <label class="form-label">Titel *</label>
                        <input class="form-control" @bind="_prTitel" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Beschreibung</label>
                        <textarea class="form-control" @bind="_prBody" rows="3"></textarea>
                    </div>
                    <div style="display:flex;gap:.5rem">
                        <button class="btn btn-success" @onclick="PullRequestErstellenAsync" disabled="@_processing">🔀 PR erstellen</button>
                        <button class="btn btn-ghost" @onclick="() => _showPullRequestForm = false">Abbrechen</button>
                    </div>
                </div>
            }
        </div>

        <!-- Rechte Spalte: KI-Prompt + Protokoll -->
        <div>
            <!-- KI-Anfrage nach Start bis zum Abschluss sichtbar -->
            @if (_aufgabe.Status is AufgabeStatus.InBearbeitung or AufgabeStatus.KiAktiv)
            {
                <div class="card">
                    <div class="card-title">💬 KI-Anfrage</div>
                    <div class="form-group">
                        <label class="form-label">Agent auswählen</label>
                        <select class="form-control" @bind="_kiAgentName">
                            <option value="">– Agent wählen –</option>
                            @foreach (var a in _agenten)
                            {
                                <option value="@a.Name">@a.Name</option>
                            }
                        </select>
                    </div>
                    <div class="form-group">
                        <label class="form-label">KI-Plugin</label>
                        <select class="form-control" @bind="_selectedKiPluginPrefix">
                            @if (_kiPlugins.Count == 0)
                            {
                                <option value="">– Kein KI-Plugin verfügbar –</option>
                            }
                            else
                            {
                                @foreach (var plugin in _kiPlugins)
                                {
                                    <option value="@plugin.PluginPrefix">@plugin.PluginName (@plugin.PluginPrefix)</option>
                                }
                            }
                        </select>
                    </div>
                    @if (_protokoll.Any(p => p.Typ == ProtokollTyp.Prompt))
                    {
                        <div class="form-group">
                            <label class="form-label">Kontextmodus</label>
                            <select class="form-control" value="@_folgeKontextmodus" @onchange="FolgeKontextmodusGeaendert">
                                <option value="@FolgeanweisungsKontextmodus.KontextMitgeben">Kontext mitgeben</option>
                                <option value="@FolgeanweisungsKontextmodus.KontextIgnorieren">Kontext ignorieren</option>
                                <option value="@FolgeanweisungsKontextmodus.KontextNeuBeginnen">Kontext neu beginnen</option>
                            </select>
                        </div>
                        @if (_folgeKontextmodus == FolgeanweisungsKontextmodus.KontextNeuBeginnen)
                        {
                            <div class="alert alert-warning" style="margin-bottom:.75rem">
                                <strong>Achtung:</strong> Der bisherige Kontextverlauf dieser Aufgabe wird beim Senden zurückgesetzt.
                                <div style="margin-top:.5rem">
                                    <label style="display:flex;gap:.5rem;align-items:center;cursor:pointer">
                                        <input type="checkbox" @bind="_folgeKontextNeuBeginnenBestaetigt" />
                                        Ich habe verstanden, dass der bisherige Kontext verworfen wird.
                                    </label>
                                </div>
                            </div>
                        }
                    }
                    <div class="form-group">
                        <label class="form-label">Prompt *</label>
                        <textarea class="form-control" @bind="_prompt" rows="4" placeholder="Beschreibe was die KI tun soll..."></textarea>
                    </div>
                    <button class="btn btn-primary" @onclick="KiStartenAsync" disabled="@_processing">
                        ▶️ Senden
                    </button>
                </div>
            }

            @if (_aufgabe.Status == AufgabeStatus.KiAktiv && _streamingLines.Count > 0)
            {
                <div class="card">
                    <div class="card-title"><div class="spinner" style="display:inline-block;width:12px;height:12px;margin-right:.5rem"></div> KI arbeitet...</div>
                    <div class="streaming-output" id="streamingOutput">
                        @foreach (var line in _streamingLines.ToArray())
                        {
                            <div>@(string.IsNullOrEmpty(line) ? "\u00A0" : line)</div>
                        }
                    </div>
                </div>
            }

            <!-- Protokoll -->
            <div class="card">
                <div class="card-title">📜 Protokoll</div>
                @if (_protokoll.Count == 0)
                {
                    <p style="color:#4b5563">Kein Protokoll vorhanden.</p>
                }
                else
                {
                    <div class="protokoll-container">
                        @foreach (var eintrag in _protokoll)
                        {
                            <div class="protokoll-entry">
                                <div class="protokoll-time">@eintrag.Zeitstempel.ToLocalTime().ToString("dd.MM.yyyy HH:mm:ss") @(eintrag.AgentName is not null ? $"[{eintrag.AgentName}]" : "")</div>
                                <div class="@GetProtokollCssClass(eintrag.Typ)">
                                    <strong>@GetProtokollLabel(eintrag.Typ):</strong>
                                    <div class="protokoll-markdown markdown-preview">@RenderProtokollInhalt(eintrag.Inhalt)</div>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>

        </div>
    </div>
}

<!-- Modal: Agentenpaket & Agent wählen beim Starten -->
@if (_showStartDialog)
{
    <div class="modal-backdrop" @onclick="StartDialogSchliessen"></div>
    <div class="modal-dialog">
        <div class="modal-header">
            <span class="modal-title">🚀 Entwicklung starten</span>
            <button class="btn btn-ghost" style="padding:.2rem .5rem" @onclick="StartDialogSchliessen">✕</button>
        </div>
        <div class="modal-body">
            <div class="form-group">
                <label class="form-label">Agentenpaket</label>
                <select class="form-control" @bind="_selectedPaketName" @bind:after="AgentenLadenAsync">
                    <option value="">– Kein Paket –</option>
                    @foreach (var p in _agentenpakete)
                    {
                        <option value="@p.Name">@p.Name (@p.Agenten.Count Agenten)</option>
                    }
                </select>
            </div>
            @if (_agenten.Count > 0)
            {
                <div class="form-group">
                    <label class="form-label">Agent</label>
                    <select class="form-control" @bind="_selectedAgentName">
                        <option value="">– Agenten wählen –</option>
                        @foreach (var a in _agenten)
                        {
                            <option value="@a.Name">@a.Name @(a.Beschreibung is not null ? $"– {a.Beschreibung}" : "")</option>
                        }
                    </select>
                </div>
            }
            <div class="form-group">
                <label class="form-label">Basis-Branch</label>
                @if (_loadingBranches)
                {
                    <div style="display:flex;align-items:center;gap:.5rem;color:#94a3b8;font-size:.85rem">
                        <div class="spinner" style="width:12px;height:12px"></div> Branches werden geladen...
                    </div>
                }
                else
                {
                    <select class="form-control" @bind="_selectedBranchName">
                        <option value="">– Neuer Branch (Standard) –</option>
                        @foreach (var branch in _remoteBranches)
                        {
                            <option value="@branch">@branch</option>
                        }
                    </select>
                    <small style="color:#4b5563;font-size:.75rem">
                        Wählen Sie einen vorhandenen Branch aus, oder lassen Sie das Feld leer um automatisch einen neuen <code>task/</code>-Branch zu erstellen.
                        Bei Auswahl des Haupt-Branches wird ebenfalls ein neuer Branch erstellt.
                    </small>
                }
            </div>
            @if (!string.IsNullOrEmpty(_fehler))
            {
                <div class="alert alert-error" style="margin-top:.5rem">@_fehler</div>
            }
        </div>
        <div class="modal-footer">
            <button class="btn btn-primary" @onclick="ProzessStartenAsync" disabled="@_processing">
                @(_processing ? "Wird gestartet..." : "🚀 Starten")
            </button>
            <button class="btn btn-ghost" @onclick="StartDialogSchliessen" disabled="@_processing">Abbrechen</button>
        </div>
    </div>
}
}
