@using Softwareschmiede.Domain.Entities
@using Softwareschmiede.Domain.Enums

<header class="diff-header" role="banner" aria-label="File information">
    <div class="diff-header__content">
        <div class="diff-header__file-info">
            <div class="diff-header__file-path">
                <span class="diff-header__file-icon">📄</span>
                <span class="diff-header__path-primary">@DiffResult.FilePath</span>
                @if (DiffResult.SourceVersion != DiffResult.TargetVersion)
                {
                    <span class="diff-header__path-secondary">
                        <small>(@DiffResult.SourceVersion → @DiffResult.TargetVersion)</small>
                    </span>
                }
            </div>
            
            <div class="diff-header__status" role="status">
                <span class="badge" 
                      style="@GetStatusColor(DiffResult.Status)"
                      aria-label="Diff status: @DiffResult.Status">
                    @GetStatusText(DiffResult.Status)
                </span>
            </div>
        </div>
        
        <div class="diff-header__statistics">
            <div class="diff-header__stat diff-header__stat--added" aria-label="Added lines">
                <span class="diff-header__stat-label">Added</span>
                <span class="diff-header__stat-value" role="presentation">+@DiffResult.AddedLines</span>
            </div>
            
            <div class="diff-header__stat diff-header__stat--removed" aria-label="Removed lines">
                <span class="diff-header__stat-label">Removed</span>
                <span class="diff-header__stat-value" role="presentation">-@DiffResult.RemovedLines</span>
            </div>
            
            <div class="diff-header__stat diff-header__stat--modified" aria-label="Modified lines">
                <span class="diff-header__stat-label">Modified</span>
                <span class="diff-header__stat-value" role="presentation">~@DiffResult.ModifiedLines</span>
            </div>
            
            <div class="diff-header__stat diff-header__stat--total" aria-label="Total lines">
                <span class="diff-header__stat-label">Total</span>
                <span class="diff-header__stat-value" role="presentation">@DiffResult.LineCount</span>
            </div>
        </div>
        
        <div class="diff-header__metadata">
            <small class="text-muted" aria-label="Generated timestamp">
                Generated: <time datetime="@DiffResult.GeneratedAt.ToString("O")">
                    @DiffResult.GeneratedAt.ToString("g")
                </time>
            </small>
            @if (!string.IsNullOrWhiteSpace(DiffResult.GeneratedBy))
            {
                <small class="text-muted ms-3" aria-label="Generated by">
                    By: @DiffResult.GeneratedBy
                </small>
            }
        </div>
    </div>
</header>

@code {
    [Parameter]
    public required DiffResult DiffResult { get; set; }

    /// <summary>
    /// Gets the status text for display.
    /// </summary>
    private static string GetStatusText(DiffResultStatus status) => status switch
    {
        DiffResultStatus.Pending => "Pending",
        DiffResultStatus.Generated => "Generated",
        DiffResultStatus.Cached => "Cached",
        DiffResultStatus.Error => "Error",
        _ => "Unknown"
    };

    /// <summary>
    /// Gets the status badge color (inline style).
    /// </summary>
    private static string GetStatusColor(DiffResultStatus status) => status switch
    {
        DiffResultStatus.Pending => "background-color: #ffc107; color: #000;",
        DiffResultStatus.Generated => "background-color: #28a745; color: #fff;",
        DiffResultStatus.Cached => "background-color: #17a2b8; color: #fff;",
        DiffResultStatus.Error => "background-color: #dc3545; color: #fff;",
        _ => "background-color: #6c757d; color: #fff;"
    };
}
