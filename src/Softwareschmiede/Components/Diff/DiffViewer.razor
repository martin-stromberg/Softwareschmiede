@implements IAsyncDisposable

@using Softwareschmiede.Application.Services
@using Softwareschmiede.Domain.Entities
@using Softwareschmiede.Domain.Enums

@inject DiffService DiffService
@inject ILogger<DiffViewer> Logger

<div class="diff-viewer" role="@(PresentationMode == DiffViewerPresentationMode.Standalone ? "main" : "region")" aria-label="Diff Viewer - File Comparison">
    @if (isLoading)
    {
        <div class="diff-viewer__loading">
            <div class="spinner-border" role="status">
                <span class="visually-hidden">Loading diff...</span>
            </div>
            <p>Loading diff comparison...</p>
        </div>
    }
    else if (errorMessage != null)
    {
        <div class="diff-viewer__error alert alert-danger" role="alert">
            <h4 class="alert-heading">Error Loading Diff</h4>
            <p>@errorMessage</p>
            @if (PresentationMode == DiffViewerPresentationMode.Standalone)
            {
                <a href="/" class="btn btn-sm btn-outline-danger">Back to Home</a>
            }
        </div>
    }
    else if (diffResult != null)
    {
        <DiffHeader DiffResult="diffResult" @key="diffResult.Id" />
        
        <DiffToolbar 
            DiffResult="diffResult"
            CurrentViewMode="currentViewMode"
            OnViewModeChanged="HandleViewModeChange"
            OnSearch="HandleSearch"
            OnNavigate="HandleNavigate"
            OnExport="HandleExport"
            @key="@($"toolbar-{diffResult.Id}")" />
        
        <div class="diff-viewer__container">
            <DiffContent 
                DiffResult="diffResult"
                ViewMode="currentViewMode"
                SelectedLines="selectedLines"
                OnLineSelected="HandleLineSelected"
                SearchTerm="currentSearchTerm"
                @key="@($"content-{diffResult.Id}-{currentViewMode}")" />
        </div>
        
        <DiffFooter 
            DiffResult="diffResult"
            TotalLines="diffResult.LineCount"
            SelectedLineCount="selectedLines.Count"
            @key="@($"footer-{diffResult.Id}")" />
    }
    else
    {
        <div class="diff-viewer__not-found alert alert-warning">
            <p>Diff not found.</p>
            @if (PresentationMode == DiffViewerPresentationMode.Standalone)
            {
                <a href="/" class="btn btn-sm btn-outline-warning">Back to Home</a>
            }
        </div>
    }
</div>

@code {
    [Parameter]
    public Guid DiffResultId { get; set; }

    [Parameter]
    public DiffViewerPresentationMode PresentationMode { get; set; } = DiffViewerPresentationMode.Embedded;

    private DiffResult? diffResult;
    private HashSet<Guid> selectedLines = [];
    private DiffViewMode currentViewMode = DiffViewMode.SideBySide;
    private string? currentSearchTerm;
    private string? errorMessage;
    private bool isLoading = true;
    private Guid? lastLoadedDiffResultId;
    private CancellationTokenSource? loadingCancellationTokenSource;
    private long loadingVersion;

    protected override async Task OnParametersSetAsync()
    {
        if (DiffResultId == Guid.Empty)
        {
            loadingCancellationTokenSource?.Cancel();
            loadingCancellationTokenSource?.Dispose();
            loadingCancellationTokenSource = null;
            Interlocked.Increment(ref loadingVersion);
            lastLoadedDiffResultId = null;
            diffResult = null;
            errorMessage = "A valid diff id is required.";
            isLoading = false;
            return;
        }

        if (lastLoadedDiffResultId == DiffResultId && !isLoading)
        {
            return;
        }

        selectedLines.Clear();
        currentViewMode = DiffViewMode.SideBySide;
        currentSearchTerm = null;
        lastLoadedDiffResultId = DiffResultId;
        await LoadDiffAsync(DiffResultId);
    }

    private async Task LoadDiffAsync(Guid diffResultId)
    {
        loadingCancellationTokenSource?.Cancel();
        loadingCancellationTokenSource?.Dispose();
        loadingCancellationTokenSource = new CancellationTokenSource();
        var cancellationToken = loadingCancellationTokenSource.Token;
        var currentVersion = Interlocked.Increment(ref loadingVersion);

        isLoading = true;
        errorMessage = null;
        diffResult = null;

        try
        {
            Logger.LogInformation("Loading diff with ID: {DiffResultId}", diffResultId);

            var loadedDiff = await DiffService.GetDiffAsync(diffResultId, cancellationToken);
            if (cancellationToken.IsCancellationRequested || currentVersion != loadingVersion)
            {
                return;
            }

            diffResult = loadedDiff;

            if (diffResult == null)
            {
                errorMessage = $"Diff with ID '{diffResultId}' not found.";
                Logger.LogWarning("Diff not found: {DiffResultId}", diffResultId);
            }
            else
            {
                Logger.LogInformation(
                    "Diff loaded successfully. File: {FilePath}, Blocks: {BlockCount}, Lines: {LineCount}",
                    diffResult.FilePath, diffResult.DiffBlocks?.Count ?? 0, diffResult.LineCount);
            }
        }
        catch (OperationCanceledException)
        {
            Logger.LogDebug("Diff loading canceled for {DiffResultId}", diffResultId);
        }
        catch (Exception ex)
        {
            errorMessage = "An error occurred while loading the diff. Please try again.";
            Logger.LogError(ex, "Error loading diff with ID: {DiffResultId}", diffResultId);
        }
        finally
        {
            if (currentVersion == loadingVersion)
            {
                isLoading = false;
            }
        }
    }

    private Task HandleViewModeChange(DiffViewMode newMode)
    {
        currentViewMode = newMode;
        Logger.LogInformation("View mode changed to: {ViewMode}", newMode);
        return Task.CompletedTask;
    }

    private Task HandleSearch(string? searchTerm)
    {
        currentSearchTerm = searchTerm;
        Logger.LogInformation("Search term updated: {SearchTerm}", searchTerm ?? "(cleared)");
        return Task.CompletedTask;
    }

    private Task HandleNavigate(NavigationDirection direction)
    {
        Logger.LogInformation("Navigate: {Direction}", direction);
        // Navigation logic to be implemented in DiffContent
        return Task.CompletedTask;
    }

    private Task HandleLineSelected(Guid lineId)
    {
        if (selectedLines.Contains(lineId))
        {
            selectedLines.Remove(lineId);
        }
        else
        {
            selectedLines.Add(lineId);
        }
        
        Logger.LogInformation("Line selected: {LineId}, Total selected: {Count}", lineId, selectedLines.Count);
        return Task.CompletedTask;
    }

    private async Task HandleExport(ExportFormat format)
    {
        try
        {
            Logger.LogInformation("Exporting diff in format: {Format}", format);
            // Export logic to be implemented
            await Task.CompletedTask;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error exporting diff");
        }
    }

    async ValueTask IAsyncDisposable.DisposeAsync()
    {
        loadingCancellationTokenSource?.Cancel();
        loadingCancellationTokenSource?.Dispose();
        await Task.CompletedTask;
    }
}
