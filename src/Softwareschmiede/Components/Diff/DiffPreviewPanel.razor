@using Softwareschmiede.Domain.ValueObjects

<div class="diff-preview-panel">
    @if (!HasSelectedFile)
    {
        <p class="text-muted">Wählen Sie links eine Datei aus.</p>
    }
    else if (Preview is null)
    {
        <p class="text-muted">Dateivorschau wird geladen…</p>
    }
    else if (!string.IsNullOrWhiteSpace(Preview.Hint))
    {
        <div class="alert alert-warning">@Preview.Hint</div>
        @if (!string.IsNullOrWhiteSpace(Preview.CurrentContent))
        {
            <pre class="workspace-preview">@Preview.CurrentContent</pre>
        }
    }
    else if (DiffResultId.HasValue)
    {
        <DiffViewer DiffResultId="DiffResultId.Value"
                    PresentationMode="DiffViewerPresentationMode.Embedded"
                    @key="@($"{DiffResultId.Value}:{Preview.RelativePath}")" />
    }
    else if (Preview.IsDeleted)
    {
        <div class="alert alert-warning">Datei gelöscht. Für diese Datei ist kein Diff verfügbar.</div>
    }
    else
    {
        <div class="alert alert-info">Für diese Datei ist kein DiffResult vorhanden.</div>
    }
</div>

@code {
    [Parameter]
    public bool HasSelectedFile { get; set; }

    [Parameter]
    public FilePreview? Preview { get; set; }

    [Parameter]
    public Guid? DiffResultId { get; set; }
}
