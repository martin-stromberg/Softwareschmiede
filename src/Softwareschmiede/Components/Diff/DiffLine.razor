@using Softwareschmiede.Domain.Entities
@using Softwareschmiede.Domain.Enums
@using DomainDiffLine = Softwareschmiede.Domain.Entities.DiffLine

<article class="diff-line" 
         @key="LineData.Id"
         role="article"
         aria-label="@GetAriaLabel()"
         data-line-id="@LineData.Id"
         data-line-status="@LineData.LineStatus"
         data-source-line="@LineData.SourceLineNumber"
         data-target-line="@LineData.TargetLineNumber">
    
    <!-- Line Numbers Section -->
    <div class="diff-line__numbers">
        <span class="diff-line__number diff-line__number--source" 
              role="doc-pagebreak"
              aria-label="Source line number: @(LineData.SourceLineNumber?.ToString() ?? "N/A")">
            @if (LineData.SourceLineNumber.HasValue)
            {
                @LineData.SourceLineNumber.Value
            }
        </span>
        <span class="diff-line__number-separator">|</span>
        <span class="diff-line__number diff-line__number--target"
              role="doc-pagebreak"
              aria-label="Target line number: @(LineData.TargetLineNumber?.ToString() ?? "N/A")">
            @if (LineData.TargetLineNumber.HasValue)
            {
                @LineData.TargetLineNumber.Value
            }
        </span>
    </div>

    <!-- Change Indicator Section -->
    <div class="diff-line__indicator" 
         role="img"
         aria-label="@GetIndicatorAriaLabel()"
         title="@GetIndicatorTooltip()">
        @GetIndicatorSymbol()
    </div>

    <!-- Line Content Section -->
    <div class="diff-line__content">
        <code class="diff-line__code" aria-hidden="true">@LineData.Content</code>
    </div>

    <!-- Selection Checkbox (optional) -->
    @if (ShowSelectionCheckbox)
    {
        <div class="diff-line__selection">
            <input type="checkbox" 
                   class="form-check-input"
                   aria-label="Select line @(LineData.SourceLineNumber ?? LineData.TargetLineNumber ?? 0)"
                   @onchange="HandleSelectionChanged"
                   @key="@($"select-{LineData.Id}")" />
        </div>
    }

    <!-- Copy to Clipboard Button (optional) -->
    @if (ShowCopyButton)
    {
        <button class="diff-line__copy btn btn-sm btn-outline-secondary"
                title="Copy line content"
                aria-label="Copy line content"
                @onclick="HandleCopyContent"
                @key="@($"copy-{LineData.Id}")">
            📋
        </button>
    }
</article>

@code {
    [Parameter]
    public required DomainDiffLine LineData { get; set; }

    [Parameter]
    public bool IsSelected { get; set; }

    [Parameter]
    public EventCallback<Guid> OnSelected { get; set; }

    [Parameter]
    public EventCallback<string> OnCopied { get; set; }

    [Parameter]
    public bool ShowSelectionCheckbox { get; set; } = false;

    [Parameter]
    public bool ShowCopyButton { get; set; } = true;

    [Inject]
    private ILogger<DiffLine> Logger { get; set; } = null!;

    /// <summary>
    /// Gets the indicator symbol based on line status.
    /// </summary>
    private string GetIndicatorSymbol() => LineData.LineStatus switch
    {
        DiffLineStatus.Added => "+",
        DiffLineStatus.Removed => "−",
        DiffLineStatus.Modified => "~",
        DiffLineStatus.Context => " ",
        _ => "?"
    };

    /// <summary>
    /// Gets the CSS class for the indicator.
    /// </summary>
    private string GetIndicatorClass() => $"diff-line__indicator--{LineData.LineStatus.ToString().ToLowerInvariant()}";

    /// <summary>
    /// Gets the ARIA label describing the line status.
    /// </summary>
    private string GetIndicatorAriaLabel() => LineData.LineStatus switch
    {
        DiffLineStatus.Added => "Line added",
        DiffLineStatus.Removed => "Line removed",
        DiffLineStatus.Modified => "Line modified",
        DiffLineStatus.Context => "Unchanged context line",
        _ => "Unknown line status"
    };

    /// <summary>
    /// Gets the tooltip text for the indicator.
    /// </summary>
    private string GetIndicatorTooltip() => GetIndicatorAriaLabel();

    /// <summary>
    /// Gets a comprehensive ARIA label for the entire line.
    /// </summary>
    private string GetAriaLabel() => 
        $"{GetIndicatorAriaLabel()}. " +
        $"Source line {LineData.SourceLineNumber?.ToString() ?? "N/A"}, " +
        $"Target line {LineData.TargetLineNumber?.ToString() ?? "N/A"}. " +
        $"Content: {EscapeContentForAria(LineData.Content)}";

    /// <summary>
    /// Escapes content for ARIA labels (truncate long lines).
    /// </summary>
    private static string EscapeContentForAria(string content) =>
        content.Length > 100 ? content[..100] + "..." : content;

    /// <summary>
    /// Handles line selection/deselection.
    /// </summary>
    private async Task HandleSelectionChanged(ChangeEventArgs e)
    {
        if (e.Value is bool isChecked)
        {
            Logger.LogInformation("Line selection changed: {LineId}, IsChecked: {IsChecked}", LineData.Id, isChecked);
            await OnSelected.InvokeAsync(LineData.Id);
        }
    }

    /// <summary>
    /// Handles copying line content to clipboard.
    /// </summary>
    private async Task HandleCopyContent()
    {
        try
        {
            Logger.LogInformation("Copying line content: {LineId}", LineData.Id);
            await OnCopied.InvokeAsync(LineData.Content);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error copying line content");
        }
    }
}
