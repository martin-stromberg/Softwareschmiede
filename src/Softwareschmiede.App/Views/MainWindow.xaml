<Window x:Class="Softwareschmiede.App.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:Softwareschmiede.App.Views"
        xmlns:vm="clr-namespace:Softwareschmiede.App.ViewModels"
        xmlns:controls="clr-namespace:Softwareschmiede.App.Controls"
        Title="{Binding Title}"
        Icon="/images/Softwareschmiede.ico"
        Width="1280" Height="800"
        MinWidth="900" MinHeight="600"
        Background="{DynamicResource BackgroundBrush}">

    <Window.Resources>
        <DataTemplate DataType="{x:Type vm:DashboardViewModel}">
            <views:DashboardView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ProjectListViewModel}">
            <views:ProjectListView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ProjectDetailViewModel}">
            <views:ProjectDetailView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:TaskDetailViewModel}">
            <views:TaskDetailView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SettingsViewModel}">
            <views:SettingsView />
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Seitenleiste -->
        <Border Grid.Column="0"
                Background="{DynamicResource SidebarBackgroundBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,1,0"
                Width="{Binding IsNavigationExpanded, Converter={StaticResource BoolToWidthConverter}}"
                MinWidth="48">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0">
                    <!-- Toggle Navigation -->
                    <Button Content="☰"
                            Command="{Binding ToggleNavigationCommand}"
                            Margin="8,8,8,16"
                            Padding="8,4"
                            Background="Transparent"
                            BorderThickness="0"
                            HorizontalAlignment="Left"
                            FontSize="16" />

                    <!-- Navigation Items -->
                    <Button Command="{Binding NavigateToDashboardCommand}"
                            AutomationProperties.Name="Dashboard"
                            Margin="4,2"
                            Padding="8,8"
                            Background="Transparent"
                            BorderThickness="0"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Left">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⊞" FontSize="16" VerticalAlignment="Center" />
                            <TextBlock Text=" Dashboard" Visibility="{Binding IsNavigationExpanded, Converter={StaticResource BoolToVisibilityConverter}}" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding NavigateToProjectListCommand}"
                            AutomationProperties.Name=" Projekte"
                            Margin="4,2"
                            Padding="8,8"
                            Background="Transparent"
                            BorderThickness="0"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Left">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📁" FontSize="16" VerticalAlignment="Center" />
                            <TextBlock Text=" Projekte" Visibility="{Binding IsNavigationExpanded, Converter={StaticResource BoolToVisibilityConverter}}" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding NavigateToSettingsCommand}"
                            AutomationProperties.Name=" Einstellungen"
                            Margin="4,2"
                            Padding="8,8"
                            Background="Transparent"
                            BorderThickness="0"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Left">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⚙" FontSize="16" VerticalAlignment="Center" />
                            <TextBlock Text=" Einstellungen" Visibility="{Binding IsNavigationExpanded, Converter={StaticResource BoolToVisibilityConverter}}" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <!-- Separator -->
                    <Border Height="1"
                            Background="{DynamicResource BorderBrush}"
                            Margin="8,8" />

                    <!-- Sektion: Aktive Aufgaben -->
                    <TextBlock Text="Aktive Aufgaben"
                               FontSize="11"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               Margin="8,8,8,4"
                               Visibility="{Binding IsDashboardVisible, Converter={StaticResource InverseBoolToVisibilityConverter}}" />
                </StackPanel>

                <ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Visibility="{Binding IsDashboardVisible, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                    <controls:ActiveTasksListControl ItemsSource="{Binding AktiveAufgabenListe}"
                                                      NavigateCommand="{Binding NavigateZuAufgabeCommand}" />
                </ScrollViewer>

                <StackPanel Grid.Row="2"
                            Margin="4,8,4,8">
                    <Border Height="1"
                            Background="{DynamicResource BorderBrush}"
                            Margin="4,0,4,8" />

                    <TextBlock Text="{Binding CurrentVersion}"
                               AutomationProperties.AutomationId="AppVersionText"
                               FontSize="11"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               Margin="8,0,8,8"
                               Visibility="{Binding IsNavigationExpanded, Converter={StaticResource BoolToVisibilityConverter}}" />

                    <Button Command="{Binding UpdateStartenCommand}"
                            Visibility="{Binding UpdateVerfuegbar, Converter={StaticResource BoolToVisibilityConverter}}"
                            AutomationProperties.Name="Programmupdate starten"
                            ToolTip="{Binding VerfuegbaresUpdate.Version, StringFormat=Update auf Version {0} vorbereiten}"
                            Margin="0,2"
                            Padding="8,8"
                            Background="Transparent"
                            BorderThickness="0"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Left">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⇧" FontSize="16" VerticalAlignment="Center" />
                            <TextBlock Text=" Update"
                                       Visibility="{Binding IsNavigationExpanded, Converter={StaticResource BoolToVisibilityConverter}}"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding UpdatePruefenCommand}"
                            AutomationProperties.Name="Programmupdate prüfen"
                            ToolTip="Auf Programmupdate prüfen"
                            Margin="0,2"
                            Padding="8,8"
                            Background="Transparent"
                            BorderThickness="0"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Left">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⟳" FontSize="16" VerticalAlignment="Center" />
                            <TextBlock Text=" Prüfen"
                                       Visibility="{Binding IsNavigationExpanded, Converter={StaticResource BoolToVisibilityConverter}}"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Inhaltsbereich -->
        <ContentControl Grid.Column="1"
                        Content="{Binding CurrentView}"
                        Margin="0" />
    </Grid>
</Window>
