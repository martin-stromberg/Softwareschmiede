<Window x:Class="Softwareschmiede.App.Views.PluginSelectionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="KI-Plugin auswählen"
        Background="{DynamicResource SurfaceBrush}"
        Width="420"
        Height="260"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Titel -->
        <TextBlock Grid.Row="0"
                   Text="KI-Plugin auswählen"
                   FontSize="20"
                   FontWeight="SemiBold"
                   Foreground="{DynamicResource PrimaryTextBrush}"
                   Margin="0,0,0,16" />

        <!-- Plugin-Auswahl -->
        <ComboBox Grid.Row="1"
                  AutomationProperties.Name="PluginAuswahl"
                  ItemsSource="{Binding VerfuegbarePlugins}"
                  SelectedItem="{Binding SelectedPluginPrefix, Mode=TwoWay}"
                  Background="{DynamicResource BackgroundBrush}"
                  Padding="8,6"
                  Margin="0,0,0,12" />

        <!-- Checkbox: Für Projekt verwenden -->
        <CheckBox Grid.Row="2"
                  AutomationProperties.Name="FuerProjektVerwenden"
                  Content="Für dieses Projekt verwenden"
                  IsChecked="{Binding SaveAsProjectDefault, Mode=TwoWay}"
                  Foreground="{DynamicResource PrimaryTextBrush}"
                  Margin="0,0,0,12" />

        <!-- Buttons -->
        <StackPanel Grid.Row="4"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,16,0,0">
            <Button Content="Abbrechen"
                    AutomationProperties.Name="Abbrechen"
                    Command="{Binding AbbrechenCommand}"
                    Padding="12,6"
                    Margin="0,0,8,0" />
            <Button Content="OK"
                    AutomationProperties.Name="OK"
                    Command="{Binding BestaetigenCommand}"
                    Padding="12,6"
                    Background="{DynamicResource AccentBrush}"
                    Foreground="White"
                    BorderThickness="0" />
        </StackPanel>
    </Grid>
</Window>
