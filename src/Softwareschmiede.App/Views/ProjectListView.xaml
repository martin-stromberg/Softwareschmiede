<UserControl x:Class="Softwareschmiede.App.Views.ProjectListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:Softwareschmiede.App.Controls"
             Background="{DynamicResource BackgroundBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Ribbon-Menü (Office-Stil) -->
        <Border Grid.Row="0"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="8,8,8,8">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom">

                <!-- Gruppe: Projekt -->
                <controls:RibbonGroup GruppenName="Projekt">
                    <controls:RibbonGroup.ItemsContent>
                        <controls:RibbonLargeButton ButtonIcon="➕"
                                                    ButtonText="Neu"
                                                    AutomationName="Neu"
                                                    ButtonCommand="{Binding ZeigeErstellungsFormularCommand}" />
                    </controls:RibbonGroup.ItemsContent>
                </controls:RibbonGroup>

            </StackPanel>
        </Border>

        <!-- Projekt-Dashboard -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <ItemsControl ItemsSource="{Binding Projekte}"
                          Margin="24">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{DynamicResource SurfaceBrush}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="12"
                                Width="280"
                                Height="180"
                                Margin="0,0,16,16"
                                Padding="20"
                                Cursor="Hand"
                                Focusable="True"
                                KeyboardNavigation.IsTabStop="True">
                            <Border.InputBindings>
                                <MouseBinding Command="{Binding DataContext.WaehleProjektCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                             CommandParameter="{Binding}"
                                             MouseAction="LeftClick" />
                                <KeyBinding Command="{Binding DataContext.WaehleProjektCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            Key="Return" />
                            </Border.InputBindings>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <!-- Projektsymbol -->
                                <Border Grid.Row="0"
                                        Background="{DynamicResource AccentBrush}"
                                        Width="48"
                                        Height="48"
                                        CornerRadius="12"
                                        Margin="0,0,0,12"
                                        HorizontalAlignment="Left">
                                    <TextBlock Text="📁"
                                               FontSize="24"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center" />
                                </Border>

                                <!-- Projekttitel -->
                                <TextBlock Grid.Row="1"
                                           Text="{Binding Name}"
                                           FontSize="18"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource PrimaryTextBrush}"
                                           TextTrimming="CharacterEllipsis"
                                           Margin="0,0,0,8" />

                                <!-- Kurzbeschreibung -->
                                <TextBlock Grid.Row="2"
                                           Text="{Binding Beschreibung}"
                                           Foreground="{DynamicResource SecondaryTextBrush}"
                                           FontSize="13"
                                           TextWrapping="Wrap"
                                           TextTrimming="CharacterEllipsis"
                                           VerticalAlignment="Top" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Projektdetail (Vollbild-Overlay) -->
        <ContentControl Grid.Row="0"
                        Grid.RowSpan="2"
                        Content="{Binding DetailViewModel}"
                        Panel.ZIndex="13"
                        Visibility="{Binding DetailViewModel, Converter={StaticResource NullOrEmptyToVisibilityConverter}}" />

        <!-- Fehlermeldung (ZIndex über Modal-Overlays, damit sie auch bei offenem Dialog sichtbar ist) -->
        <Border Grid.Row="0"
                Grid.RowSpan="2"
                Background="{DynamicResource ErrorBrush}"
                CornerRadius="8"
                Padding="16,12"
                HorizontalAlignment="Center"
                VerticalAlignment="Bottom"
                Margin="0,0,0,24"
                Panel.ZIndex="20"
                Visibility="{Binding FehlerMeldung, Converter={StaticResource NullOrEmptyToVisibilityConverter}}">
            <TextBlock Text="{Binding FehlerMeldung}"
                       Foreground="White"
                       FontSize="14"
                       TextWrapping="Wrap" />
        </Border>
    </Grid>
</UserControl>
