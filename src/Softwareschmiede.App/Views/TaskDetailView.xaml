<UserControl x:Class="Softwareschmiede.App.Views.TaskDetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:Softwareschmiede.App.Controls"
             Background="{DynamicResource BackgroundBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Ribbon-Menü -->
        <Border Grid.Row="0"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="8,8,8,8">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom">

                <!-- Gruppe: Navigation -->
                <controls:RibbonGroup GruppenName="Navigation">
                    <controls:RibbonGroup.ItemsContent>
                        <controls:RibbonLargeButton ButtonIcon="←"
                                                    ButtonText="Zurück"
                                                    AutomationName="Zurück"
                                                    ButtonCommand="{Binding ZurueckCommand}" />
                    </controls:RibbonGroup.ItemsContent>
                </controls:RibbonGroup>

                <!-- Gruppe: Aufgabe -->
                <controls:RibbonGroup GruppenName="Aufgabe">
                    <controls:RibbonGroup.ItemsContent>
                        <StackPanel Orientation="Horizontal">
                            <controls:RibbonLargeButton ButtonIcon="💾"
                                                        ButtonText="Speichern"
                                                        AutomationName="Speichern"
                                                        ButtonCommand="{Binding SpeichernCommand}" />
                            <controls:RibbonLargeButton ButtonIcon="🗑"
                                                        ButtonText="Löschen"
                                                        AutomationName="Löschen"
                                                        ButtonCommand="{Binding LoeschenCommand}" />
                            <controls:RibbonLargeButton ButtonIcon="▶"
                                                        ButtonText="Starten"
                                                        AutomationName="Starten"
                                                        ButtonCommand="{Binding StartenCommand}" />
                            <controls:RibbonLargeButton ButtonIcon="✓"
                                                        ButtonText="Beenden"
                                                        AutomationName="Beenden"
                                                        ButtonCommand="{Binding AufgabeAbschliessenCommand}" />
                        </StackPanel>
                    </controls:RibbonGroup.ItemsContent>
                </controls:RibbonGroup>

                <!-- Gruppe: CLI -->
                <controls:RibbonGroup GruppenName="CLI">
                    <controls:RibbonGroup.ItemsContent>
                        <StackPanel Orientation="Horizontal">
                            <controls:RibbonLargeButton ButtonIcon="🔌"
                                                        ButtonText="Plugin ändern"
                                                        AutomationName="PluginAendern"
                                                        ButtonCommand="{Binding PluginAendernCommand}" />
                            <controls:RibbonLargeButton ButtonIcon="▶"
                                                        ButtonText="CLI starten"
                                                        AutomationName="CliNeustarten"
                                                        ButtonCommand="{Binding CliNeustartenCommand}"
                                                        Visibility="{Binding KannCliNeuStarten, Converter={StaticResource BoolToVisibilityConverter}}" />
                            <controls:RibbonLargeButton ButtonIcon="■"
                                                        ButtonText="Stoppen"
                                                        AutomationName="CliStoppen"
                                                        ButtonCommand="{Binding CliStoppenCommand}"
                                                        Visibility="{Binding IsCliRunning, Converter={StaticResource BoolToVisibilityConverter}}" />
                            <StackPanel Margin="12,0,0,0"
                                        VerticalAlignment="Center">
                                <TextBlock Text="Promptvorlage"
                                           FontSize="11"
                                           Foreground="{DynamicResource SecondaryTextBrush}"
                                           Margin="0,0,0,2" />
                                <ComboBox ItemsSource="{Binding PromptVorlagen}"
                                          SelectedItem="{Binding SelectedPromptVorlage, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          DisplayMemberPath="Name"
                                          AutomationProperties.Name="PromptVorlagenAuswahl"
                                          Width="220"
                                          IsEnabled="{Binding KannPromptVorlageSenden}"
                                          Padding="6,4" />
                                <StackPanel Orientation="Horizontal"
                                            Margin="0,6,0,0">
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="Zielzeit"
                                                   FontSize="11"
                                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                                   Margin="0,0,0,2" />
                                        <StackPanel Orientation="Horizontal">
                                            <TextBox Text="{Binding ScheduledPromptTargetHours, UpdateSourceTrigger=PropertyChanged}"
                                                     AutomationProperties.Name="ScheduledPromptStunde"
                                                     Width="40"
                                                     IsEnabled="{Binding KannPromptVorlageSenden}"
                                                     Padding="6,4" />
                                            <TextBlock Text=":"
                                                       VerticalAlignment="Center"
                                                       Margin="4,0"
                                                       Foreground="{DynamicResource SecondaryTextBrush}" />
                                            <TextBox Text="{Binding ScheduledPromptTargetMinutes, UpdateSourceTrigger=PropertyChanged}"
                                                     AutomationProperties.Name="ScheduledPromptMinute"
                                                     Width="40"
                                                     IsEnabled="{Binding KannPromptVorlageSenden}"
                                                     Padding="6,4" />
                                        </StackPanel>
                                    </StackPanel>
                                    <controls:RibbonLargeButton ButtonIcon="⏰"
                                                                ButtonText="Zeitgesteuert senden"
                                                                AutomationName="ZeitgesteuertSenden"
                                                                ButtonCommand="{Binding SchedulePromptCommand}" />
                                </StackPanel>
                                <StackPanel Margin="0,4,0,0"
                                            Visibility="{Binding ScheduledPromptStatus, Converter={StaticResource NullOrEmptyToVisibilityConverter}}">
                                    <TextBlock Text="{Binding ScheduledPromptStatus}"
                                               AutomationProperties.Name="ScheduledPromptStatus"
                                               FontSize="12"
                                               Foreground="{DynamicResource AccentBrush}" />
                                    <TextBlock Text="{Binding ScheduledPromptTimeDisplay}"
                                               FontSize="11"
                                               Foreground="{DynamicResource SecondaryTextBrush}" />
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </controls:RibbonGroup.ItemsContent>
                </controls:RibbonGroup>

                <!-- Gruppe: Issue -->
                <controls:RibbonGroup GruppenName="Issue"
                                      Visibility="{Binding CanAssignIssue, Converter={StaticResource BoolToVisibilityConverter}}">
                    <controls:RibbonGroup.ItemsContent>
                        <StackPanel Orientation="Horizontal">
                            <controls:RibbonLargeButton ButtonIcon="🔗"
                                                        ButtonText="Issue zuweisen"
                                                        AutomationName="IssueZuweisen"
                                                        ButtonCommand="{Binding IssueZuweisenCommand}" />
                            <controls:RibbonLargeButton ButtonIcon="🌐"
                                                        ButtonText="Issue öffnen"
                                                        AutomationName="IssueOeffnen"
                                                        ButtonCommand="{Binding IssueBrowserOeffnenCommand}"
                                                        Visibility="{Binding CurrentIssueReferenz, Converter={StaticResource NullOrEmptyToVisibilityConverter}}" />
                        </StackPanel>
                    </controls:RibbonGroup.ItemsContent>
                </controls:RibbonGroup>

            </StackPanel>
        </Border>

        <!-- Fehler -->
        <Border Grid.Row="1"
                Background="{DynamicResource ErrorBrush}"
                Padding="12,8"
                Visibility="{Binding FehlerMeldung, Converter={StaticResource NullOrEmptyToVisibilityConverter}}">
            <TextBlock AutomationProperties.Name="FehlerMeldung"
                       AutomationProperties.HelpText="{Binding FehlerMeldung}"
                       Text="{Binding FehlerMeldung}" Foreground="White" />
        </Border>

        <!-- Hauptinhalt -->
        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0"
                        Orientation="Horizontal"
                        Background="{DynamicResource SurfaceBrush}"
                        Margin="16,8">
                <TextBlock Text="Ansicht:"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource SecondaryTextBrush}"
                           FontSize="12"
                           Margin="0,0,8,0" />
                <Button Content="Info"
                        AutomationProperties.Name="InfoCliToggle"
                        Command="{Binding InfoViewCommand}"
                        Padding="12,4"
                        Margin="0,0,6,0"
                        FontSize="12" />
                <Button Content="CLI"
                        AutomationProperties.Name="CliViewButton"
                        Command="{Binding CliViewCommand}"
                        Padding="12,4"
                        Margin="0,0,6,0"
                        FontSize="12"
                        Visibility="{Binding ShowCliPanel, Converter={StaticResource BoolToVisibilityConverter}}" />
                <Button Content="Diff"
                        AutomationProperties.Name="DiffViewButton"
                        Command="{Binding DiffViewCommand}"
                        Padding="12,4"
                        FontSize="12"
                        Visibility="{Binding ShowDiffPanel, Converter={StaticResource BoolToVisibilityConverter}}" />
            </StackPanel>

            <Grid Grid.Row="1">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Visibility="{Binding IsInfoViewSelected, Converter={StaticResource BoolToVisibilityConverter}}">
                    <StackPanel Margin="24">
                        <Border Background="{DynamicResource SurfaceBrush}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="12"
                                Padding="16"
                                Margin="0,0,0,12"
                                Visibility="{Binding ShowEditPanel, Converter={StaticResource BoolToVisibilityConverter}}">
                            <StackPanel>
                                <TextBlock Text="Aufgabe bearbeiten"
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource PrimaryTextBrush}"
                                           Margin="0,0,0,16" />

                                <TextBlock Text="Titel"
                                           FontSize="12"
                                           Foreground="{DynamicResource SecondaryTextBrush}"
                                           Margin="0,0,0,4" />
                                <TextBox Text="{Binding EditTitel, UpdateSourceTrigger=PropertyChanged}"
                                         AutomationProperties.Name="EditTitel"
                                         FontSize="14"
                                         Foreground="{DynamicResource PrimaryTextBrush}"
                                         Background="{DynamicResource BackgroundBrush}"
                                         BorderBrush="{DynamicResource BorderBrush}"
                                         BorderThickness="1"
                                         Padding="8,6"
                                         Margin="0,0,0,16" />

                                <TextBlock Text="Anforderungsbeschreibung"
                                           FontSize="12"
                                           Foreground="{DynamicResource SecondaryTextBrush}"
                                           Margin="0,0,0,4" />
                                <TextBox Text="{Binding EditAnforderungsBeschreibung, UpdateSourceTrigger=PropertyChanged}"
                                         AutomationProperties.Name="EditAnforderungsBeschreibung"
                                         FontSize="14"
                                         Foreground="{DynamicResource PrimaryTextBrush}"
                                         Background="{DynamicResource BackgroundBrush}"
                                         BorderBrush="{DynamicResource BorderBrush}"
                                         BorderThickness="1"
                                         Padding="8,6"
                                         MinHeight="120"
                                         TextWrapping="Wrap"
                                         AcceptsReturn="True" />
                            </StackPanel>
                        </Border>

                        <Border Background="{DynamicResource SurfaceBrush}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="12"
                                Padding="16"
                                Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="{Binding AufgabeTitel}"
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource PrimaryTextBrush}"
                                           Margin="0,0,0,8" />
                                <TextBlock Text="{Binding AufgabeStatus}"
                                           FontSize="12"
                                           Foreground="{DynamicResource AccentBrush}"
                                           Margin="0,0,0,8" />
                                <TextBlock Text="{Binding Aufgabe.AnforderungsBeschreibung}"
                                           FontSize="13"
                                           Foreground="{DynamicResource SecondaryTextBrush}"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>

                        <Border Background="{DynamicResource SurfaceBrush}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="12"
                                Padding="16">
                            <StackPanel>
                                <TextBlock Text="Protokoll"
                                           FontSize="14"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource PrimaryTextBrush}"
                                           Margin="0,0,0,8" />
                                <ListBox ItemsSource="{Binding Protokolleintraege}"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                         MaxHeight="400">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="4,2" MaxWidth="800">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="160" />
                                                    <ColumnDefinition Width="80" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0"
                                                           Text="{Binding Zeitstempel, StringFormat='{}{0:dd.MM.yyyy HH:mm:ss}'}"
                                                           FontSize="11"
                                                           Foreground="{DynamicResource SecondaryTextBrush}"
                                                           VerticalAlignment="Top" />
                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding Typ}"
                                                           FontSize="11"
                                                           Foreground="{DynamicResource AccentBrush}"
                                                           VerticalAlignment="Top" />
                                                <TextBlock Grid.Column="2"
                                                           Text="{Binding Inhalt}"
                                                           FontSize="12"
                                                           Foreground="{DynamicResource PrimaryTextBrush}"
                                                           TextWrapping="Wrap" />
                                            </Grid>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <controls:TerminalControl x:Name="TerminalConsole"
                                          AutomationProperties.Name="TerminalConsole"
                                          Visibility="{Binding IsCliViewSelected, Converter={StaticResource BoolToVisibilityConverter}}" />

                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Visibility="{Binding IsDiffViewSelected, Converter={StaticResource BoolToVisibilityConverter}}">
                    <StackPanel Margin="24">
                        <Border Background="{DynamicResource SurfaceBrush}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="12"
                                Padding="16">
                            <TextBlock Text="Diff-Ansicht wird hier angezeigt... (Implementierung folgt später)"
                                       FontSize="14"
                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                       FontStyle="Italic"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Grid>

        <!-- Statusleiste -->
        <Border Grid.Row="3"
                Background="{DynamicResource SidebarBackgroundBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="12,4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <controls:StatusIndicatorControl Grid.Column="0"
                                                 Status="{Binding AufgabeStatus, Mode=OneWay}"
                                                 BranchName="{Binding AufgabeBranchName, Mode=OneWay}" />
                <TextBlock Grid.Column="1"
                           Text="{Binding CliStatusText}"
                           Foreground="{DynamicResource SecondaryTextBrush}"
                           FontSize="12"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Center"
                           AutomationProperties.Name="CliStatusText" />
                <TextBlock Grid.Column="2"
                           Text="{Binding AktiverCliName, StringFormat='CLI: {0}'}"
                           Foreground="{DynamicResource SecondaryTextBrush}"
                           FontSize="12"
                           VerticalAlignment="Center"
                           AutomationProperties.Name="AktiverCliName"
                           Visibility="{Binding AktiverCliName, Converter={StaticResource NullOrEmptyToVisibilityConverter}}" />
                
            </Grid>            
        </Border>
    </Grid>
</UserControl>
