<UserControl x:Class="Softwareschmiede.App.Views.ProjectDetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:Softwareschmiede.App.Views"
             xmlns:controls="clr-namespace:Softwareschmiede.App.Controls"
             Background="{DynamicResource BackgroundBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Ribbon-Menü (Office-Stil) -->
        <Border Grid.Row="0"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="8,8,8,8">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom">

                <!-- Gruppe: Navigation -->
                <controls:RibbonGroup GruppenName="Navigation">
                    <controls:RibbonGroup.ItemsContent>
                        <controls:RibbonLargeButton ButtonIcon="←"
                                                    ButtonText="Zurück"
                                                    AutomationName="Zurück"
                                                    ButtonCommand="{Binding ZurueckCommand}" />
                    </controls:RibbonGroup.ItemsContent>
                </controls:RibbonGroup>

                <!-- Gruppe: Projekt -->
                <controls:RibbonGroup GruppenName="Projekt">
                    <controls:RibbonGroup.ItemsContent>
                        <StackPanel Orientation="Horizontal">
                            <controls:RibbonLargeButton ButtonIcon="💾"
                                                        ButtonText="Speichern"
                                                        AutomationName="Speichern"
                                                        ButtonCommand="{Binding SpeichernCommand}" />
                            <controls:RibbonLargeButton ButtonIcon="🗑"
                                                        ButtonText="Löschen"
                                                        AutomationName="Löschen"
                                                        ButtonCommand="{Binding LoeschenCommand}" />
                        </StackPanel>
                    </controls:RibbonGroup.ItemsContent>
                </controls:RibbonGroup>

                <!-- Gruppe: Aufgaben -->
                <controls:RibbonGroup GruppenName="Aufgaben">
                    <controls:RibbonGroup.ItemsContent>
                        <StackPanel Orientation="Horizontal">
                            <controls:RibbonLargeButton ButtonIcon="➕"
                                                        ButtonText="Neue Aufgabe"
                                                        AutomationName="AufgabeNeu"
                                                        ButtonCommand="{Binding AufgabeErstellenCommand}" />
                            <StackPanel VerticalAlignment="Center">
                                <controls:RibbonSmallButton ButtonIcon="🔽"
                                                            ButtonText="Filter"
                                                            AutomationName="Filter"
                                                            ButtonCommand="{Binding FilterCommand}" />
                            </StackPanel>
                        </StackPanel>
                    </controls:RibbonGroup.ItemsContent>
                </controls:RibbonGroup>

                <!-- Gruppe: Repository -->
                <controls:RibbonGroup GruppenName="Repository">
                    <controls:RibbonGroup.ItemsContent>
                        <StackPanel>
                            <controls:RibbonSmallButton ButtonIcon="🔗"
                                                        ButtonText="Zuweisen"
                                                        AutomationName="Zuweisen"
                                                        ButtonCommand="{Binding RepositoryZuweisenCommand}" />
                            <controls:RibbonSmallButton ButtonIcon="🌐"
                                                        ButtonText="Öffnen"
                                                        AutomationName="Öffnen"
                                                        ButtonCommand="{Binding RepositoryOeffnenCommand}" />
                        </StackPanel>
                    </controls:RibbonGroup.ItemsContent>
                </controls:RibbonGroup>

            </StackPanel>
        </Border>

        <!-- Inhalt -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="24">

                <!-- Ladesymbol -->
                <TextBlock Text="Wird geladen…"
                           Foreground="{DynamicResource SecondaryTextBrush}"
                           Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}" />

                <!-- Filter-Overlay -->
                <Border Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="12"
                        Padding="20"
                        Visibility="{Binding IsFilterOverlayVisible, Converter={StaticResource BoolToVisibilityConverter}}">
                    <StackPanel>
                        <TextBlock Text="Aufgaben filtern"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource PrimaryTextBrush}"
                                   Margin="0,0,0,12" />
                        <StackPanel Orientation="Horizontal">
                            <RadioButton Content="Alle"
                                         GroupName="AufgabenFilter"
                                         IsChecked="{Binding AufgabenFilter, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Alle}"
                                         Margin="0,0,16,0" />
                            <RadioButton Content="Aktiv"
                                         GroupName="AufgabenFilter"
                                         IsChecked="{Binding AufgabenFilter, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Aktiv}"
                                         Margin="0,0,16,0" />
                            <RadioButton Content="Archiviert"
                                         GroupName="AufgabenFilter"
                                         IsChecked="{Binding AufgabenFilter, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Archiviert}" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Projekt-Kachel (immer sichtbar, auch im Anlage-Modus) -->
                <Border Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="12"
                        Padding="20">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!-- Symbol und Titel -->
                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
                            <TextBlock Text="📁"
                                       FontSize="32"
                                       Margin="0,0,12,0"
                                       VerticalAlignment="Center" />
                            <TextBox x:Name="ProjektNameTextBox"
                                     Text="{Binding ProjektName, UpdateSourceTrigger=PropertyChanged}"
                                     AutomationProperties.Name="ProjektName"
                                     FontSize="20"
                                     FontWeight="SemiBold"
                                     Foreground="{DynamicResource PrimaryTextBrush}"
                                     Background="{DynamicResource BackgroundBrush}"
                                     BorderBrush="{DynamicResource BorderBrush}"
                                     BorderThickness="1"
                                     Padding="8,4"
                                     MinWidth="200"
                                     HorizontalAlignment="Stretch"
                                     VerticalAlignment="Center" />
                        </StackPanel>

                        <!-- Beschreibung -->
                        <TextBox Grid.Row="1"
                                 Text="{Binding ProjektBeschreibung, UpdateSourceTrigger=PropertyChanged}"
                                 AutomationProperties.Name="ProjektBeschreibung"
                                 FontSize="14"
                                 Foreground="{DynamicResource SecondaryTextBrush}"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Padding="0"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True" />
                    </Grid>
                </Border>

                <!-- Aufgaben-Kachel (nur wenn Projekt bereits persistiert ist) -->
                <Border Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="12"
                        Padding="20"
                        Margin="0 10"
                        Visibility="{Binding IsNeuanlage, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <!-- Titel -->
                        <TextBlock Grid.Row="0"
                                   Text="Aufgaben"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource PrimaryTextBrush}"
                                   Margin="0,0,0,12" />

                        <!-- Aufgabenliste -->
                        <ListBox Grid.Row="1"
                                 AutomationProperties.Name="AufgabenListe"
                                 ItemsSource="{Binding GefilterteAufgaben}"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 MaxHeight="400">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="8,4">
                                        <Grid.RowDefinitions>
                                            <RowDefinition />
                                            <RowDefinition />
                                        </Grid.RowDefinitions>
                                        <TextBlock Grid.Row="0"
                                                   Text="{Binding Titel}"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource PrimaryTextBrush}"
                                                   TextTrimming="CharacterEllipsis" />
                                        <TextBlock Grid.Row="1"
                                                   Text="{Binding Status}"
                                                   FontSize="11"
                                                   Foreground="{DynamicResource SecondaryTextBrush}" />
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="AutomationProperties.Name" Value="{Binding Titel}" />
                                    <EventSetter Event="MouseDoubleClick" Handler="AufgabeDoubleClick" />
                                </Style>
                            </ListBox.ItemContainerStyle>
                        </ListBox>
                    </Grid>
                </Border>

                <!-- Offene Anforderungen (Issues) -->
                <Border Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="12"
                        Padding="20"
                        Margin="0 10"
                        Visibility="{Binding KannIssuesLaden, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0"
                                   Text="Offene Anforderungen"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource PrimaryTextBrush}"
                                   Margin="0,0,0,8" />

                        <TextBlock Grid.Row="1"
                                   Text="Wird geladen…"
                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                   Visibility="{Binding IsLoadingIssues, Converter={StaticResource BoolToVisibilityConverter}}"
                                   Margin="0,0,0,8" />

                        <ListBox Grid.Row="2"
                                 AutomationProperties.Name="IssueVorschlaege"
                                 ItemsSource="{Binding IssueVorschlaege}"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 MaxHeight="300">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="8,4">
                                        <Grid.RowDefinitions>
                                            <RowDefinition />
                                            <RowDefinition />
                                        </Grid.RowDefinitions>
                                        <StackPanel Grid.Row="0" Orientation="Horizontal">
                                            <TextBlock FontSize="11"
                                                       Foreground="{DynamicResource AccentBrush}"
                                                       Margin="0,0,6,0">
                                                <Run Text="#" /><Run Text="{Binding Nummer}" />
                                            </TextBlock>
                                            <TextBlock Text="{Binding Titel}"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                                       TextTrimming="CharacterEllipsis" />
                                        </StackPanel>
                                        <TextBlock Grid.Row="1"
                                                   Text="Offene Anforderung"
                                                   FontSize="11"
                                                   Foreground="{DynamicResource AccentBrush}" />
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <EventSetter Event="MouseDoubleClick" Handler="IssueDoubleClick" />
                                </Style>
                            </ListBox.ItemContainerStyle>
                        </ListBox>
                    </Grid>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
