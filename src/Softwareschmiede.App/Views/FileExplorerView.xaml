<UserControl x:Class="Softwareschmiede.App.Views.FileExplorerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:Softwareschmiede.App.Controls"
             xmlns:vo="clr-namespace:Softwareschmiede.Domain.ValueObjects;assembly=Softwareschmiede"
             Background="{DynamicResource BackgroundBrush}">
    <UserControl.Resources>
        <HierarchicalDataTemplate DataType="{x:Type vo:WorkspaceFileNode}"
                                   ItemsSource="{Binding Children}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="{Binding Converter={StaticResource WorkspaceFileNodeIconConverter}}"
                           FontSize="12"
                           Margin="0,0,4,0"
                           VerticalAlignment="Center" />
                <TextBlock Grid.Column="1"
                           Text="{Binding Name}"
                           Foreground="{DynamicResource PrimaryTextBrush}"
                           FontSize="12"
                           VerticalAlignment="Center" />
                <TextBlock Grid.Column="2"
                           Text="{Binding Converter={StaticResource WorkspaceFileNodeStatusIconConverter}}"
                           FontSize="12"
                           Margin="8,0,0,0"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center" />
            </Grid>
        </HierarchicalDataTemplate>
        <Style x:Key="FileExplorerBaumItemContainerStyle" TargetType="TreeViewItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        </Style>
        <Style x:Key="StandardBaumItemContainerStyle" TargetType="TreeViewItem" BasedOn="{StaticResource FileExplorerBaumItemContainerStyle}">
            <Setter Property="AutomationProperties.Name" Value="{Binding Name}" />
        </Style>
    </UserControl.Resources>
    <Grid Margin="16">
        <!-- Split-View: Baum + Inhalt -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250" MinWidth="150" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Baum: Standardmodus (Arbeitsbaum) -->
            <TreeView Grid.Column="0"
                      x:Name="StandardBaum"
                      AutomationProperties.Name="FileExplorerBaum"
                      Background="{DynamicResource SurfaceBrush}"
                      BorderBrush="{DynamicResource BorderBrush}"
                      BorderThickness="1"
                      ItemsSource="{Binding Wurzelknoten}"
                      SelectedItemChanged="OnBaumSelectedItemChanged"
                      TreeViewItem.Expanded="OnBaumKnotenExpanded"
                      TreeViewItem.Collapsed="OnBaumKnotenCollapsed"
                      ItemContainerStyle="{StaticResource StandardBaumItemContainerStyle}">
                <TreeView.Style>
                    <Style TargetType="TreeView">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding AktuellerModus}" Value="Vergleich">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TreeView.Style>
            </TreeView>

            <!-- Baum: Vergleichsmodus (Commits mit geänderten Dateien) -->
            <TreeView Grid.Column="0"
                      x:Name="VergleichBaum"
                      AutomationProperties.Name="FileExplorerVergleichBaum"
                      Background="{DynamicResource SurfaceBrush}"
                      BorderBrush="{DynamicResource BorderBrush}"
                      BorderThickness="1"
                      ItemsSource="{Binding CommitGruppen}"
                      SelectedItemChanged="OnBaumSelectedItemChanged"
                      TreeViewItem.Expanded="OnCommitKnotenExpanded"
                      ItemContainerStyle="{StaticResource FileExplorerBaumItemContainerStyle}">
                <TreeView.Resources>
                    <HierarchicalDataTemplate DataType="{x:Type vo:BranchCommit}"
                                               ItemsSource="{Binding Files}">
                        <StackPanel Orientation="Vertical">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding Subject}"
                                           Foreground="{DynamicResource PrimaryTextBrush}"
                                           FontSize="12"
                                           Margin="0,0,6,0" />
                                <TextBlock Text="{Binding ShortSha}"
                                           Foreground="{DynamicResource SecondaryTextBrush}"
                                           FontSize="11" />
                                <TextBlock Text="Lädt…"
                                           AutomationProperties.Name="FileExplorerCommitLaedt"
                                           Foreground="{DynamicResource SecondaryTextBrush}"
                                           FontSize="11"
                                           Margin="6,0,0,0"
                                           Visibility="{Binding IsLoadingFiles, Converter={StaticResource BoolToVisibilityConverter}}" />
                            </StackPanel>
                            <TextBlock Text="{Binding ErrorMessage}"
                                       AutomationProperties.Name="FileExplorerCommitFehler"
                                       Foreground="{DynamicResource ErrorBrush}"
                                       FontSize="11"
                                       TextWrapping="Wrap"
                                       Visibility="{Binding ErrorMessage, Converter={StaticResource NullOrEmptyToVisibilityConverter}}" />
                        </StackPanel>
                    </HierarchicalDataTemplate>
                </TreeView.Resources>
                <TreeView.Style>
                    <Style TargetType="TreeView">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding AktuellerModus}" Value="Standard">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TreeView.Style>
            </TreeView>

            <GridSplitter Grid.Column="1"
                          Width="5"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          Background="{DynamicResource BorderBrush}" />

            <!-- Rechts: Dateiinhalt (Standard) bzw. DiffViewer (Vergleich) -->
            <Grid Grid.Column="2"
                  Margin="8,0,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0"
                            Orientation="Horizontal"
                            Margin="0,0,0,8">
                    <StackPanel Orientation="Horizontal"
                                Visibility="{Binding ZeigtDiffAnsicht, Converter={StaticResource BoolToVisibilityConverter}}">
                        <Button Content="◀"
                                ToolTip="Vorherige Änderung"
                                AutomationProperties.Name="FileExplorerVorherigeAenderungButton"
                                AutomationProperties.HelpText="Vorherige Änderung"
                                Command="{Binding VorherigeAenderungCommand}"
                                Padding="10,4"
                                Margin="0,0,6,0"
                                FontSize="12" />
                        <Button Content="▶"
                                ToolTip="Nächste Änderung"
                                AutomationProperties.Name="FileExplorerNaechsteAenderungButton"
                                AutomationProperties.HelpText="Nächste Änderung"
                                Command="{Binding NaechsteAenderungCommand}"
                                Padding="10,4"
                                Margin="0,0,6,0"
                                FontSize="12" />
                    </StackPanel>
                </StackPanel>

                <Grid Grid.Row="1">
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Auto"
                                  Visibility="{Binding ZeigtDiffAnsicht, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                        <TextBlock AutomationProperties.Name="FileExplorerDateiInhalt"
                                   Text="{Binding DateiInhalt}"
                                   FontFamily="Consolas"
                                   FontSize="12"
                                   TextWrapping="NoWrap"
                                   Foreground="{DynamicResource PrimaryTextBrush}" />
                    </ScrollViewer>

                    <controls:DiffViewer x:Name="DiffViewerControl"
                                         Lines="{Binding DiffZeilen}"
                                         Visibility="{Binding ZeigtDiffAnsicht, Converter={StaticResource BoolToVisibilityConverter}}" />
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
