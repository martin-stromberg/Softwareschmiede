<UserControl x:Class="Softwareschmiede.App.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:Softwareschmiede.App.Controls"
             Background="{DynamicResource BackgroundBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Ribbon-Menü (Office-Stil) -->
        <Border Grid.Row="0"
        Background="{DynamicResource SurfaceBrush}"
        BorderBrush="{DynamicResource BorderBrush}"
        BorderThickness="0,0,0,1"
        Padding="8,8,8,8">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom">

                <!-- Gruppe: Einstellungen -->
                <controls:RibbonGroup GruppenName="Projekt">
                    <controls:RibbonGroup.ItemsContent>
                        <StackPanel Orientation="Horizontal">
                            <controls:RibbonLargeButton ButtonIcon="💾"
                                                ButtonText="Speichern"
                                                AutomationName="Speichern"
                                                ButtonCommand="{Binding SpeichernCommand}" />
                            <controls:RibbonLargeButton ButtonIcon="↺"
                                                ButtonText="Löschen"
                                                AutomationName="Löschen"
                                                ButtonCommand="{Binding VerwerfenCommand}" />
                        </StackPanel>
                    </controls:RibbonGroup.ItemsContent>
                </controls:RibbonGroup>

            </StackPanel>
        </Border>

        <!-- Meldungen -->
        <StackPanel Grid.Row="1">
            <Border Background="{DynamicResource SuccessBrush}"
                    CornerRadius="4"
                    Padding="12,8"
                    Margin="0,0,0,8"
                    Visibility="{Binding ErfolgsMeldung, Converter={StaticResource NullOrEmptyToVisibilityConverter}}">
                <TextBlock Text="{Binding ErfolgsMeldung}" Foreground="White" />
            </Border>
            <Border Background="{DynamicResource ErrorBrush}"
                    CornerRadius="4"
                    Padding="12,8"
                    Margin="0,0,0,8"
                    Visibility="{Binding FehlerMeldung, Converter={StaticResource NullOrEmptyToVisibilityConverter}}">
                <TextBlock Text="{Binding FehlerMeldung}" Foreground="White" />
            </Border>
        </StackPanel>

        <!-- Arbeitsverzeichnis -->
        <StackPanel Grid.Row="2" Margin="0,0,0,16" MaxWidth="600" HorizontalAlignment="Left">
            <TextBlock Text="Arbeitsverzeichnis"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource PrimaryTextBrush}"
                       Margin="0,0,0,4" />
            <TextBlock Text="Verzeichnis, in dem Repository-Klone gespeichert werden."
                       FontSize="12"
                       Foreground="{DynamicResource SecondaryTextBrush}"
                       Margin="0,0,0,8" />
            <TextBox Text="{Binding Arbeitsverzeichnis, UpdateSourceTrigger=PropertyChanged}"
                     Padding="8,6"
                     BorderBrush="{DynamicResource BorderBrush}" />
        </StackPanel>

        <!-- Dark Mode -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,0,0,16">
            <CheckBox IsChecked="{Binding IsDarkMode, Mode=OneWay}"
                      Content="Dark Mode aktivieren"
                      Foreground="{DynamicResource PrimaryTextBrush}"
                      VerticalAlignment="Center" />
        </StackPanel>

        <!-- Standard KI-Plugin -->
        <StackPanel Grid.Row="4" Margin="0,0,0,24" MaxWidth="400" HorizontalAlignment="Left">
            <TextBlock Text="Standard KI-Plugin"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource PrimaryTextBrush}"
                       Margin="0,0,0,4" />
            <TextBox Text="{Binding DefaultKiPlugin, UpdateSourceTrigger=PropertyChanged}"
                     Padding="8,6"
                     BorderBrush="{DynamicResource BorderBrush}" />
        </StackPanel>
        
    </Grid>
</UserControl>
