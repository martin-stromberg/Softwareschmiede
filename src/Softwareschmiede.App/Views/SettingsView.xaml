<UserControl x:Class="Softwareschmiede.App.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:Softwareschmiede.App.Controls"
             xmlns:local="clr-namespace:Softwareschmiede.App.Views"
             Background="{DynamicResource BackgroundBrush}">
    <UserControl.Resources>
        <local:PluginSettingFieldTemplateSelector x:Key="FieldTemplateSelector">
            <local:PluginSettingFieldTemplateSelector.TextTemplate>
                <DataTemplate>
                    <TextBox Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                             AutomationProperties.Name="{Binding Field.Key}"
                             Width="320"
                             HorizontalAlignment="Left" />
                </DataTemplate>
            </local:PluginSettingFieldTemplateSelector.TextTemplate>
            <local:PluginSettingFieldTemplateSelector.SecretTemplate>
                <DataTemplate>
                    <PasswordBox Tag="{Binding}"
                                 Width="320"
                                 HorizontalAlignment="Left"
                                 Loaded="OnPasswordBoxLoaded"
                                 PasswordChanged="OnPasswordChanged" />
                </DataTemplate>
            </local:PluginSettingFieldTemplateSelector.SecretTemplate>
            <local:PluginSettingFieldTemplateSelector.UrlTemplate>
                <DataTemplate>
                    <TextBox Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                             Width="320"
                             HorizontalAlignment="Left" />
                </DataTemplate>
            </local:PluginSettingFieldTemplateSelector.UrlTemplate>
            <local:PluginSettingFieldTemplateSelector.IntegerTemplate>
                <DataTemplate>
                    <TextBox Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                             Width="120"
                             HorizontalAlignment="Left" />
                </DataTemplate>
            </local:PluginSettingFieldTemplateSelector.IntegerTemplate>
            <local:PluginSettingFieldTemplateSelector.BooleanTemplate>
                <DataTemplate>
                    <CheckBox IsChecked="{Binding BoolValue, UpdateSourceTrigger=PropertyChanged}"
                              Content="{Binding Field.Label}" />
                </DataTemplate>
            </local:PluginSettingFieldTemplateSelector.BooleanTemplate>
            <local:PluginSettingFieldTemplateSelector.EnumTemplate>
                <DataTemplate>
                    <ComboBox SelectedValue="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                              AutomationProperties.Name="{Binding Field.Key}"
                              ItemsSource="{Binding Field.EnumOptions}"
                              Width="220"
                              HorizontalAlignment="Left" />
                </DataTemplate>
            </local:PluginSettingFieldTemplateSelector.EnumTemplate>
            <local:PluginSettingFieldTemplateSelector.FilePathTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal">
                        <TextBox Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                                 Width="280"
                                 VerticalAlignment="Center" />
                        <Button Content="…"
                                Width="28"
                                Margin="4,0,0,0"
                                VerticalAlignment="Center"
                                Click="OnDateiAuswaehlenClick" />
                    </StackPanel>
                </DataTemplate>
            </local:PluginSettingFieldTemplateSelector.FilePathTemplate>
            <local:PluginSettingFieldTemplateSelector.CommandLineParametersTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal">
                        <TextBox Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                                 AutomationProperties.Name="CommandLineParameters"
                                 Width="280"
                                 VerticalAlignment="Center" />
                        <Button Content="?"
                                AutomationProperties.Name="CliHilfeButton"
                                Width="28"
                                Margin="4,0,0,0"
                                VerticalAlignment="Center"
                                Click="OnHilfeButtonClick" />
                    </StackPanel>
                </DataTemplate>
            </local:PluginSettingFieldTemplateSelector.CommandLineParametersTemplate>
        </local:PluginSettingFieldTemplateSelector>

        <Style x:Key="PluginActivationListBoxItemStyle" TargetType="ListBoxItem">
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AccentHoverBrush}" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AccentBrush}" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsSelected" Value="True" />
                                    <Condition Property="IsMouseOver" Value="True" />
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AccentHoverBrush}" />
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Ribbon-Menü (Office-Stil) -->
        <Border Grid.Row="0"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="8,8,8,8">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom">

                <!-- Gruppe: Einstellungen -->
                <controls:RibbonGroup GruppenName="Projekt">
                    <controls:RibbonGroup.ItemsContent>
                        <StackPanel Orientation="Horizontal">
                            <controls:RibbonLargeButton ButtonIcon="💾"
                                                ButtonText="Speichern"
                                                AutomationName="Speichern"
                                                ButtonCommand="{Binding SpeichernCommand}" />
                            <controls:RibbonLargeButton ButtonIcon="↺"
                                                ButtonText="Verwerfen"
                                                AutomationName="Verwerfen"
                                                ButtonCommand="{Binding VerwerfenCommand}" />
                        </StackPanel>
                    </controls:RibbonGroup.ItemsContent>
                </controls:RibbonGroup>

            </StackPanel>
        </Border>

        <!-- Meldungen -->
        <StackPanel Grid.Row="1" Margin="8,0,8,0">
            <Border Background="{DynamicResource SuccessBrush}"
                    CornerRadius="4"
                    Padding="12,8"
                    Margin="0,8,0,8"
                    Visibility="{Binding ErfolgsMeldung, Converter={StaticResource NullOrEmptyToVisibilityConverter}}">
                <TextBlock Text="{Binding ErfolgsMeldung}" Foreground="White" />
            </Border>
            <Border Background="{DynamicResource ErrorBrush}"
                    CornerRadius="4"
                    Padding="12,8"
                    Margin="0,8,0,8"
                    Visibility="{Binding FehlerMeldung, Converter={StaticResource NullOrEmptyToVisibilityConverter}}">
                <TextBlock AutomationProperties.Name="FehlerMeldung"
                           AutomationProperties.HelpText="{Binding FehlerMeldung}"
                           Text="{Binding FehlerMeldung}" Foreground="White" />
            </Border>
        </StackPanel>

        <!-- Registerkarten -->
        <TabControl Grid.Row="2" Margin="08,8,8,8" HorizontalAlignment="Stretch"
                    Background="{DynamicResource SurfaceBrush}"
                    Foreground="{DynamicResource PrimaryTextBrush}">
            <TabControl.Resources>
                <Style TargetType="TabItem">
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="TabItem">
                                <Border Name="Border"
                                        BorderThickness="1,1,1,0"
                                        BorderBrush="{DynamicResource BorderBrush}"
                                        CornerRadius="4,4,0,0" Margin="2,0">
                                    <ContentPresenter x:Name="ContentSite"
                                        VerticalAlignment="Center"
                                        HorizontalAlignment="Center"
                                        ContentSource="Header"
                                        Margin="10,2"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="Border" Property="Background" Value="{DynamicResource SelectedTabBackgroundBrush}" />
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="False">
                                        <Setter TargetName="Border" Property="Background" Value="{DynamicResource UnselectedTabBackgroundBrush}" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </TabControl.Resources>
            <TabItem>
                <TabItem.Header >
                    <StackPanel Orientation="Horizontal" Margin="0">
                        <Ellipse Width="10" Height="10" Fill="DarkGray" Margin="0,0,8,0"/>
                        <TextBlock Background="Transparent" Foreground="{DynamicResource PrimaryTextBrush}">Allgemein</TextBlock>
                    </StackPanel>
                </TabItem.Header>
                <StackPanel Margin="16">
                    <!-- Designmodus -->
                    <StackPanel Margin="0,0,0,16" MaxWidth="600" HorizontalAlignment="Left">
                        <Label Content="Design"
                           FontWeight="SemiBold"
                           Margin="0,0,0,4" />
                        <ComboBox SelectedValue="{Binding DesignMode, UpdateSourceTrigger=PropertyChanged}"
                                  AutomationProperties.Name="DesignMode"
                                  ItemsSource="{Binding DesignModes}"
                                  Margin="0,0,0,12"
                                  Padding="8,6">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>

                    <!-- Arbeitsverzeichnis -->
                    <StackPanel Margin="0,0,0,16" MaxWidth="600" HorizontalAlignment="Left">
                        <TextBlock Text="Arbeitsverzeichnis"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource PrimaryTextBrush}"
                                   Margin="0,0,0,4" />
                        <TextBlock Text="Verzeichnis, in dem Repository-Klone gespeichert werden."
                                   FontSize="12"
                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                   Margin="0,0,0,8" />
                        <TextBox Text="{Binding Arbeitsverzeichnis, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="8,6"
                                 BorderBrush="{DynamicResource BorderBrush}" />
                    </StackPanel>

                    <!-- IDE -->
                    <StackPanel Margin="0,0,0,16" MaxWidth="600" HorizontalAlignment="Left">
                        <TextBlock Text="IDE"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource PrimaryTextBrush}"
                                   Margin="0,0,0,8" />
                        <CheckBox Content="Visual Studio Code oeffnen, wenn keine Visual-Studio-Solution gefunden wurde"
                                  AutomationProperties.Name="OpenVisualStudioCodeWhenNoSolutionFound"
                                  IsChecked="{Binding OpenVisualStudioCodeWhenNoSolutionFound, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                </StackPanel>
            </TabItem>
            <TabItem>
                <TabItem.Header >
                    <StackPanel Orientation="Horizontal" Margin="0">
                        <TextBlock Margin="0,0,8,0" Foreground="{DynamicResource SecondaryTextBrush}" Opacity="0.88" >🔌</TextBlock>
                        <TextBlock Background="Transparent" Foreground="{DynamicResource PrimaryTextBrush}">Plugins</TextBlock>
                    </StackPanel>
                </TabItem.Header>
                <Grid Margin="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="360" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- Linke Spalte: Standard-Plugin-Auswahl und Aktivierungslisten -->
                    <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <!-- Standard SCM-Plugin -->
                            <StackPanel Margin="0,0,0,16">
                                <TextBlock Text="Standard SCM-Plugin"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource PrimaryTextBrush}"
                                           Margin="0,0,0,4" />
                                <ComboBox SelectedValue="{Binding DefaultScmPlugin, UpdateSourceTrigger=PropertyChanged}"
                                          ItemsSource="{Binding ScmPlugins}"
                                          Margin="0,0,0,12"
                                          Padding="8,6"
                                          SelectionChanged="OnPluginSelectionChanged">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding PluginName}" />
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>

                                <!-- Standard KI-Plugin -->
                                <TextBlock Text="Standard KI-Plugin"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource PrimaryTextBrush}"
                                           Margin="0,0,0,4" />
                                <ComboBox SelectedValue="{Binding DefaultKiPlugin, UpdateSourceTrigger=PropertyChanged}"
                                          SelectedValuePath="PluginName"
                                          AutomationProperties.Name="DefaultKiPlugin"
                                          ItemsSource="{Binding KiPlugins}"
                                          Padding="8,6"
                                          SelectionChanged="OnPluginSelectionChanged">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding PluginName}" />
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </StackPanel>

                            <!-- Aktivierung SCM-Plugins -->
                            <TextBlock Text="Quellcodeverwaltung"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                       Margin="0,8,0,4" />
                            <ListBox ItemsSource="{Binding SourceCodeManagementPlugins}"
                                     Background="{DynamicResource SurfaceBrush}"
                                     Foreground="{DynamicResource PrimaryTextBrush}"
                                     BorderBrush="{DynamicResource BorderBrush}"
                                     Margin="0,0,0,16"
                                     ItemContainerStyle="{StaticResource PluginActivationListBoxItemStyle}"
                                     SelectionChanged="OnPluginSelectionChanged">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding PluginName}"
                                                       AutomationProperties.Name="{Binding PluginPrefix, StringFormat={}{0}.Eintrag}"
                                                       Margin="6,0,0,0"
                                                       VerticalAlignment="Center" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>

                            <!-- Aktivierung KI-Plugins -->
                            <TextBlock Text="KI"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                       Margin="0,0,0,4" />
                            <ListBox ItemsSource="{Binding DevelopmentAutomationPlugins}"
                                     Background="{DynamicResource SurfaceBrush}"
                                     Foreground="{DynamicResource PrimaryTextBrush}"
                                     BorderBrush="{DynamicResource BorderBrush}"
                                     ItemContainerStyle="{StaticResource PluginActivationListBoxItemStyle}"
                                     SelectionChanged="OnPluginSelectionChanged">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding PluginName}"
                                                       AutomationProperties.Name="{Binding PluginPrefix, StringFormat={}{0}.Eintrag}"
                                                       Margin="6,0,0,0"
                                                       VerticalAlignment="Center" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- Rechte Spalte: Einstellungen des im Aktivierungsregister ausgewählten Plugins -->
                    <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <TextBlock Text="{Binding SelectedPlugin.PluginName}"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                       Visibility="{Binding SelectedPlugin, Converter={StaticResource NullOrEmptyToVisibilityConverter}}"
                                       Margin="0,0,0,8" />
                            <CheckBox Content="Plugin aktiviert"
                                      AutomationProperties.Name="PluginAktiviert"
                                      IsChecked="{Binding SelectedPlugin.IsEnabled, Mode=TwoWay}"
                                      Visibility="{Binding SelectedPlugin, Converter={StaticResource NullOrEmptyToVisibilityConverter}}"
                                      Margin="0,0,0,12" />
                            <ItemsControl ItemsSource="{Binding SelectedPluginSettings}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="0,0,0,8">
                                            <TextBlock Text="{Binding GroupName}"
                                                       FontWeight="Bold"
                                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                                       Margin="0,10,0,5" />
                                            <ItemsControl ItemsSource="{Binding Entries}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <StackPanel Margin="0,4,0,4">
                                                            <TextBlock Text="{Binding Field.Label}"
                                                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                                                       FontSize="12"
                                                                       Margin="0,0,0,2" />
                                                            <ContentControl Content="{Binding}"
                                                                            ContentTemplateSelector="{StaticResource FieldTemplateSelector}" />
                                                            <TextBlock Text="{Binding Field.Description}"
                                                                       FontSize="11"
                                                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                                                       Visibility="{Binding Field.Description, Converter={StaticResource NullOrEmptyToVisibilityConverter}}"
                                                                       Margin="0,2,0,0" />
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </TabItem>
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal" Margin="0">
                        <TextBlock Margin="0,0,8,0" Foreground="{DynamicResource SecondaryTextBrush}" Opacity="0.88">⌘</TextBlock>
                        <TextBlock Background="Transparent" Foreground="{DynamicResource PrimaryTextBrush}">Promptvorlagen</TextBlock>
                    </StackPanel>
                </TabItem.Header>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="16" MaxWidth="900" HorizontalAlignment="Left">
                        <Button Content="Hinzufügen"
                                AutomationProperties.Name="PromptVorlageHinzufuegen"
                                Command="{Binding PromptVorlageHinzufuegenCommand}"
                                Padding="12,6"
                                HorizontalAlignment="Left"
                                Margin="0,0,0,12" />

                        <ItemsControl ItemsSource="{Binding PromptVorlagen}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{DynamicResource SurfaceBrush}"
                                            BorderBrush="{DynamicResource BorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="4"
                                            Padding="12"
                                            Margin="0,0,0,12">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="220" />
                                                <ColumnDefinition Width="16" />
                                                <ColumnDefinition Width="480" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="Name"
                                                           FontSize="12"
                                                           Foreground="{DynamicResource SecondaryTextBrush}"
                                                           Margin="0,0,0,4" />
                                                <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                                         AutomationProperties.Name="PromptVorlageName"
                                                         Padding="8,6" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="2">
                                                <TextBlock Text="Prompttext"
                                                           FontSize="12"
                                                           Foreground="{DynamicResource SecondaryTextBrush}"
                                                           Margin="0,0,0,4" />
                                                <TextBox Text="{Binding Prompttext, UpdateSourceTrigger=PropertyChanged}"
                                                         AutomationProperties.Name="PromptVorlagePrompttext"
                                                         Padding="8,6"
                                                         MinHeight="72"
                                                         AcceptsReturn="True"
                                                         TextWrapping="Wrap"
                                                         VerticalScrollBarVisibility="Auto" />
                                            </StackPanel>
                                            <Button Grid.Column="3"
                                                    Content="Löschen"
                                                    AutomationProperties.Name="PromptVorlageLoeschen"
                                                    Command="{Binding DataContext.PromptVorlageLoeschenCommand, RelativeSource={RelativeSource AncestorType=TabControl}}"
                                                    CommandParameter="{Binding}"
                                                    Padding="12,6"
                                                    Margin="12,20,0,0"
                                                    VerticalAlignment="Top" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>
