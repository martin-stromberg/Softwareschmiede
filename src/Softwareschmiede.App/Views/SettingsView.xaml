<UserControl x:Class="Softwareschmiede.App.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource BackgroundBrush}">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Einstellungen"
                   FontSize="24"
                   FontWeight="SemiBold"
                   Foreground="{DynamicResource PrimaryTextBrush}"
                   Margin="0,0,0,24" />

        <!-- Arbeitsverzeichnis -->
        <StackPanel Grid.Row="1" Margin="0,0,0,16" MaxWidth="600" HorizontalAlignment="Left">
            <TextBlock Text="Arbeitsverzeichnis"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource PrimaryTextBrush}"
                       Margin="0,0,0,4" />
            <TextBlock Text="Verzeichnis, in dem Repository-Klone gespeichert werden."
                       FontSize="12"
                       Foreground="{DynamicResource SecondaryTextBrush}"
                       Margin="0,0,0,8" />
            <TextBox Text="{Binding Arbeitsverzeichnis, UpdateSourceTrigger=PropertyChanged}"
                     Padding="8,6"
                     BorderBrush="{DynamicResource BorderBrush}" />
        </StackPanel>

        <!-- Dark Mode -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,16">
            <CheckBox IsChecked="{Binding IsDarkMode}"
                      Content="Dark Mode aktivieren"
                      Foreground="{DynamicResource PrimaryTextBrush}"
                      VerticalAlignment="Center" />
        </StackPanel>

        <!-- Standard KI-Plugin -->
        <StackPanel Grid.Row="3" Margin="0,0,0,24" MaxWidth="400" HorizontalAlignment="Left">
            <TextBlock Text="Standard KI-Plugin"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource PrimaryTextBrush}"
                       Margin="0,0,0,4" />
            <TextBox Text="{Binding DefaultKiPlugin, UpdateSourceTrigger=PropertyChanged}"
                     Padding="8,6"
                     BorderBrush="{DynamicResource BorderBrush}" />
        </StackPanel>

        <!-- Speichern-Button -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="0,0,0,16">
            <Button Content="Einstellungen speichern"
                    Command="{Binding SpeichernCommand}"
                    Padding="16,8"
                    Background="{DynamicResource AccentBrush}"
                    Foreground="White"
                    BorderThickness="0" />
        </StackPanel>

        <!-- Meldungen -->
        <StackPanel Grid.Row="5">
            <Border Background="{DynamicResource SuccessBrush}"
                    CornerRadius="4"
                    Padding="12,8"
                    Margin="0,0,0,8"
                    Visibility="{Binding ErfolgsMeldung, Converter={StaticResource NullOrEmptyToVisibilityConverter}}">
                <TextBlock Text="{Binding ErfolgsMeldung}" Foreground="White" />
            </Border>
            <Border Background="{DynamicResource ErrorBrush}"
                    CornerRadius="4"
                    Padding="12,8"
                    Visibility="{Binding FehlerMeldung, Converter={StaticResource NullOrEmptyToVisibilityConverter}}">
                <TextBlock Text="{Binding FehlerMeldung}" Foreground="White" />
            </Border>
        </StackPanel>
    </Grid>
</UserControl>
